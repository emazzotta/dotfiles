#!/bin/bash
if test "${ZSH_VERSION}"; then
    autoload bashcompinit
    bashcompinit
    compdef sshrc=ssh
fi
_agrep()
{
  local _rcd
  _rcd="${HOME}/.bashrc.d"
  [ -d "${_rcd}" ] || _rcd="${HOME}/dotfiles/bash/.bashrc.d"
  _agrep_commands=$(ls ${CUSTOM_BIN_DIR})
  if [ -d "${_rcd}" ]; then
    _agrep_commands+=$(grep -hEo '^(alias ).*' "${_rcd}"/[0-9]*.sh 2>/dev/null | sed 's/=.*$//g' | sed 's/alias //g')
    _agrep_commands+=$(grep -hEo '^(export ).*' "${_rcd}"/[0-9]*.sh 2>/dev/null | sed 's/=.*$//g' | sed 's/export //g')
  fi
  local cur prev
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  COMPREPLY=($(compgen -W "${_agrep_commands}" -- ${cur}))
}
_kubeconf()
{
  _kubeconf_options=$(ls ${KUBE_DIR} | grep kubeconfig.yaml | sed 's/-kubeconfig.yaml//g')
  local cur prev
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  COMPREPLY=($(compgen -W "${_kubeconf_options}" -- ${cur}))
}
_bundleid()
{
  while IFS= read -r line; do
    COMPREPLY+=("$line")
  done < <(find /Applications -mindepth 1 -maxdepth 1 -type d -print | sed 's/\/Applications\///g' | sed 's/ /\\ /g')
}
_compressvideo()
{
  while IFS= read -r line; do
    COMPREPLY+=("$line")
  done < <(find . -mindepth 1 -maxdepth 1 -type f -not -name ".*" -print | sed 's|./||' | sed 's/ /\\ /g')
  COMPREPLY+=($(compressvideo -h | grep '\-\-' | sed 's/^.*--/--/g' | sed 's/ .*//g'))
}
_ef()
{
  _ef_commands=$(ls ${CUSTOM_BIN_DIR})
  local cur prev
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  COMPREPLY=($(compgen -W "${_ef_commands}" -- ${cur}))
}
_repo() {
  _repo_commands=""
  for dir in $(find "${WDIR}" -mindepth 2 -maxdepth 2 -type d); do
    _repo_commands+="$(basename ${dir}) "
  done
  local cur prev
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  COMPREPLY=($(compgen -W "${_repo_commands}" -- ${cur}))
}
_cl()
{
  local cur prev
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"
  if [[ -z "${_CL_OPTS_CACHE}" ]]; then
    _CL_OPTS_CACHE=$(cl --help 2>/dev/null | grep -oE -- '(^|[[:space:],])-{1,2}[a-zA-Z][a-zA-Z0-9-]*' | tr -d ' ,' | sort -u | tr '\n' ' ')
  fi
  case "${prev}" in
    -f|--file)
      COMPREPLY=($(compgen -f -- "${cur}"))
      return 0
      ;;
    -p|--path)
      COMPREPLY=($(compgen -d -- "${cur}"))
      return 0
      ;;
  esac
  if [[ "${cur}" == -* ]]; then
    COMPREPLY=($(compgen -W "${_CL_OPTS_CACHE}" -- "${cur}"))
    return 0
  fi
  COMPREPLY=($(compgen -f -- "${cur}"))
}
_ags()
{
  local cur prev
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"
  if [[ -z "${_AGS_OPTS_CACHE}" ]]; then
    _AGS_OPTS_CACHE=$(ags --help 2>/dev/null | grep -oE -- '(^|[[:space:],])-{1,2}[a-zA-Z][a-zA-Z0-9-]*' | tr -d ' ,' | sort -u | tr '\n' ' ')
  fi
  case "${prev}" in
    -p|--path)
      COMPREPLY=($(compgen -d -- "${cur}"))
      return 0
      ;;
    -r|--file-regex|-x|--exclude|--exclude-content)
      return 0
      ;;
  esac
  if [[ "${cur}" == -* ]]; then
    COMPREPLY=($(compgen -W "${_AGS_OPTS_CACHE}" -- "${cur}"))
    return 0
  fi
}
_make_targets()
{
  local cur makefile
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  for makefile in Makefile makefile GNUmakefile; do
    if [[ -f "${makefile}" ]]; then
      local targets
      targets=$(grep -E '^[a-zA-Z0-9_.-]+:' "${makefile}" | grep -v '^\.PHONY' | sed 's/:.*//' | sort -u)
      COMPREPLY=($(compgen -W "${targets}" -- "${cur}"))
      return 0
    fi
  done
}
_envify()
{
  local cur prev _py
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"
  _py="${DOTFILESPATH:-$HOME/dotfiles}/bin/envify.py"

  if [[ -z "${_ENVIFY_OPTS_CACHE}" ]]; then
    _ENVIFY_OPTS_CACHE=$(python3 "$_py" --help 2>/dev/null \
      | grep -oE -- '(^|[[:space:],])-{1,2}[a-zA-Z][a-zA-Z0-9-]*' \
      | tr -d ' ,' | sort -u | tr '\n' ' ')
  fi

  if [[ "$cur" == -* ]]; then
    COMPREPLY=($(compgen -W "${_ENVIFY_OPTS_CACHE}" -- "$cur"))
    return 0
  fi

  local _ttl="${ENVIFY_COMPLETION_TTL:-3600}"
  local _now _mtime
  _now=$(date +%s)
  mkdir -p "${HOME}/.cache"

  if [[ "$prev" == "--bridge" ]]; then
    local _bcache="${HOME}/.cache/envify-bridge-endpoints"
    _mtime=$(date -r "$_bcache" +%s 2>/dev/null || echo 0)
    if (( _now - _mtime >= _ttl )); then
      python3 "$_py" --bridge-list 2>/dev/null \
        | python3 -c "import sys,json; print('\n'.join(e['name'] for e in json.load(sys.stdin)))" \
        > "$_bcache" 2>/dev/null || true
    fi
    [[ -f "$_bcache" ]] && COMPREPLY=($(compgen -W "$(cat "$_bcache")" -- "$cur"))
    return 0
  fi

  local _cache="${HOME}/.cache/envify-keys"
  _mtime=$(date -r "$_cache" +%s 2>/dev/null || echo 0)
  if (( _now - _mtime >= _ttl )); then
    python3 "$_py" --list > "$_cache" 2>/dev/null || true
  fi

  [[ -f "$_cache" ]] && COMPREPLY=($(compgen -W "$(cat "$_cache")" -- "$cur"))
}
_keyguard()
{
  local cur prev
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  if [[ ${COMP_CWORD} -eq 1 ]]; then
    COMPREPLY=($(compgen -W "get set list" -- "${cur}"))
    return 0
  fi

  case "${COMP_WORDS[1]}" in
    get|set)
      local _ttl="${KEYGUARD_COMPLETION_TTL:-3600}"
      local _cache="${HOME}/.cache/keyguard-keys"
      local _now _mtime
      _now=$(date +%s)
      mkdir -p "${HOME}/.cache"
      _mtime=$(date -r "$_cache" +%s 2>/dev/null || echo 0)
      if (( _now - _mtime >= _ttl )); then
        keyguard list > "$_cache" 2>/dev/null || true
      fi
      [[ -f "$_cache" ]] && COMPREPLY=($(compgen -W "$(cat "$_cache")" -- "$cur"))
      return 0
      ;;
  esac
}
complete -F _envify envify
complete -F _keyguard keyguard
complete -o nospace -F _agrep agrep
complete -o nospace -F _kubeconf kubeconf
complete -o nospace -F _bundleid bundleid
complete -o nospace -F _compressvideo compressvideo
complete -o nospace -F _ef ef
complete -o nospace -F _repo repo c
complete -o filenames -F _cl cl
complete -F _ags ags
complete -F _make_targets make m
