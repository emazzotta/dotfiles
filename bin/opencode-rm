#!/bin/bash
set -euo pipefail

DB_PATH="${OPENCODE_DB:-${HOME}/.local/share/opencode/opencode.db}"
STORAGE_DIR="${OPENCODE_STORAGE:-${HOME}/.local/share/opencode/storage}"

show_usage() {
    cat << EOF
Usage: $(basename "$0") [-n COUNT] [-y] [SEARCH]

Interactive session picker for removing opencode sessions. Multi-select
with gum; deletes from SQLite database and filesystem storage.

Options:
  -n COUNT   Number of sessions to show (default: 30)
  -m         Multi-select (space to toggle, enter to confirm)
  -y         Skip confirmation prompt
  -h         Show this help

Arguments:
  SEARCH     Optional text to filter sessions by title

Environment:
  OPENCODE_DB        Path to opencode.db (default: ~/.local/share/opencode/opencode.db)
  OPENCODE_STORAGE   Path to storage dir (default: ~/.local/share/opencode/storage)
EOF
}

fetch_sessions() {
    local count="$1" search="$2"
    [ -f "$DB_PATH" ] || { echo "Error: database not found at $DB_PATH" >&2; return 1; }

    python3 -c "
import sqlite3, json, sys
db, count, search = sys.argv[1], int(sys.argv[2]), sys.argv[3]
conn = sqlite3.connect(f'file:{db}?mode=ro', uri=True)
conn.row_factory = sqlite3.Row
if search:
    rows = conn.execute('SELECT id, title, time_updated FROM session WHERE title LIKE ? COLLATE NOCASE ORDER BY time_updated DESC LIMIT ?', (f'%{search}%', count)).fetchall()
else:
    rows = conn.execute('SELECT id, title, time_updated FROM session ORDER BY time_updated DESC LIMIT ?', (count,)).fetchall()
conn.close()
print(json.dumps([dict(r) for r in rows]))
" "$DB_PATH" "$count" "$search"
}

format_choices() {
    python3 -c "
import json, sys, time
now_ms = int(time.time() * 1000)
for s in json.loads(sys.stdin.read()):
    title = s.get('title') or 'Untitled'
    if len(title) > 45: title = title[:42] + '...'
    diff = (now_ms - s['time_updated']) // 1000
    if diff < 60: ago = 'just now'
    elif diff < 3600: ago = f'{diff // 60}m ago'
    elif diff < 86400: ago = f'{diff // 3600}h ago'
    else:
        d = diff // 86400
        ago = 'yesterday' if d == 1 else (f'{d}d ago' if d < 30 else f'{d // 30}mo ago')
    print(f\"{s['id']}\\t{title}\\t{ago}\")
"
}

delete_sessions() {
    local ids=("$@")
    python3 - "$DB_PATH" "${ids[@]}" << 'PY'
import sqlite3, sys
db, ids = sys.argv[1], sys.argv[2:]
conn = sqlite3.connect(db)
placeholders = ','.join('?' * len(ids))
for table in ('part', 'message', 'todo', 'session_share', 'session_entry'):
    conn.execute(f'DELETE FROM {table} WHERE session_id IN ({placeholders})', ids)
conn.execute(f'DELETE FROM session WHERE id IN ({placeholders})', ids)
conn.commit()
conn.close()
PY
    for sid in "${ids[@]}"; do
        for sub in session message part session_diff; do
            rm -rf "${STORAGE_DIR:?}/$sub/$sid" "${STORAGE_DIR:?}/$sub/$sid.json"
        done
    done
}

main() {
    local count=30 skip_confirm=false multi=false search=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help) show_usage; exit 0 ;;
            -n) count="$2"; shift 2 ;;
            -m) multi=true; shift ;;
            -y) skip_confirm=true; shift ;;
            -*) echo "Unknown option: $1" >&2; show_usage >&2; exit 1 ;;
            *) search="$1"; shift ;;
        esac
    done

    local json
    json=$(fetch_sessions "$count" "$search") || exit 1
    if [ -z "$json" ] || [ "$json" = "[]" ]; then
        echo "No sessions found${search:+ matching '$search'}" >&2
        exit 1
    fi

    local choices display
    choices=$(echo "$json" | format_choices)
    display=$(echo "$choices" | while IFS=$'\t' read -r sid title ago; do
        printf "%-47s %-12s %s\n" "$title" "$ago" "$sid"
    done)

    command -v gum &>/dev/null || { echo "Error: gum required" >&2; exit 1; }

    local gum_flags=("--header" "Select session to DELETE:")
    if [ "$multi" = true ]; then
        gum_flags=("--no-limit" "--header" "Select session(s) to DELETE (space=toggle, enter=confirm):")
    fi
    local selected
    selected=$(echo "$display" | gum choose "${gum_flags[@]}") || exit 1
    [ -n "$selected" ] || { echo "No selection" >&2; exit 1; }

    local ids=()
    while IFS= read -r line; do
        ids+=("$(echo "$line" | awk '{print $NF}')")
    done <<< "$selected"

    echo "About to delete ${#ids[@]} session(s):"
    echo "$selected" | sed 's/^/  /'

    if [ "$skip_confirm" = false ]; then
        gum confirm "Delete?" || { echo "Cancelled" >&2; exit 1; }
    fi

    delete_sessions "${ids[@]}"
    echo "Deleted ${#ids[@]} session(s)."
}

main "$@"
