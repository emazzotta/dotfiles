#!/bin/bash

set -euo pipefail

source "${CUSTOM_BIN_DIR}/prettyprint"

scan_dir="${WDIR}"
if [ -n "${1:-}" ]; then
    scan_dir="${1}"
fi

ignore_dirs=("dev")

output_file=$(mktemp)
branches_file=$(mktemp)
remote_branches_file=$(mktemp)
status_file=$(mktemp)
trap 'rm -f "${output_file}" "${branches_file}" "${remote_branches_file}" "${status_file}"' EXIT

separator() {
    printf "${BOLD}${CYAN}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${RESET}\n"
}

dim_separator() {
    printf "${YELLOW}в•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ңв•Ң${RESET}\n"
}

scan_repos() {
    find "${scan_dir}" -mindepth 0 -maxdepth 3 -type d -or -type l | while read -r dir; do
        skip=false
        for pattern in "${ignore_dirs[@]}"; do
            if [[ "${dir}" =~ (^|/)${pattern}$ ]]; then
                skip=true
                break
            fi
        done
        [ "${skip}" = true ] && continue
        if [ -d "${dir}/.git" ]; then
            printf '%s' "${dir}" > "${status_file}"
            current_branch=$(git -C "${dir}" rev-parse --abbrev-ref HEAD)
            shown=false
            if [[ "$(git -C "${dir}" status -s)" != "" ]]; then
                { separator; printf "${BOLD}${WHITE}%s${RESET} [git uncommitted changes]\n" "${dir}"; git -c color.ui=always -C "${dir}" status -s; } >> "${output_file}"
                shown=true
            fi
            if [[ "$(git -C "${dir}" log --branches --not --remotes)" != "" ]]; then
                { separator; printf "${BOLD}${WHITE}%s${RESET} [git unpushed changes]\n" "${dir}"; git -c color.ui=always -C "${dir}" log --pretty=format:"%h - %an, %ar: %s" --branches --not --remotes; printf '\n'; } >> "${output_file}"
                shown=true
            fi
            if [ "$(git -C "${dir}" stash list)" != "" ]; then
                { separator; printf "${BOLD}${WHITE}%s${RESET} [git stashed changes]\n" "${dir}"; git -c color.ui=always -C "${dir}" stash list; } >> "${output_file}"
                shown=true
            fi
            other_branches=$(git -C "${dir}" for-each-ref --format='%(refname:short)' refs/heads/ | grep -Ev '^(main|master)$' || true)
            if [ -n "${other_branches}" ]; then
                formatted=""
                while IFS= read -r branch; do
                    if [ "${branch}" = "${current_branch}" ]; then
                        formatted="${formatted}${BOLD}${branch}${RESET}, "
                    else
                        formatted="${formatted}${branch}, "
                    fi
                done <<< "${other_branches}"
                printf "${YELLOW}%s${RESET} [%s]\n" "${dir}" "${formatted%, }" >> "${branches_file}"
            fi
            remote_only=""
            while IFS= read -r branch; do
                if ! git -C "${dir}" show-ref --verify --quiet "refs/heads/${branch}" 2>/dev/null; then
                    remote_only="${remote_only}${branch}, "
                fi
            done < <(git -C "${dir}" for-each-ref --format='%(refname:short)' refs/remotes/origin/ \
                | grep -Ev '^origin$|origin/(HEAD|main|master)$' \
                | sed 's#^origin/##' || true)
            if [ -n "${remote_only}" ]; then
                printf "${YELLOW}%s${RESET} [%s]\n" "${dir}" "${remote_only%, }" >> "${remote_branches_file}"
            fi
        fi
    done
}

spin() {
    local spinners='в Ӣв ҷв №в ёв јв ҙв Ұв §в Үв Ҹ'
    local i=0
    while kill -0 "${SCAN_PID}" 2>/dev/null; do
        local current
        current=$(cat "${status_file}" 2>/dev/null || echo "")
        printf "\033[2K\r  ${YELLOW}%s${RESET}  %s" "${spinners:$((i % 10)):1}" "${current}" >&2
        sleep 0.1
        i=$((i + 1))
    done
    printf "\r%-100s\r" "" >&2
}

scan_repos &
SCAN_PID=$!
spin
wait "${SCAN_PID}"

cat "${output_file}"
[ -s "${output_file}" ] && separator

if [ -s "${branches_file}" ]; then
    echo
    dim_separator
    printf "${YELLOW}  other branches${RESET}\n"
    dim_separator
    cat "${branches_file}"
    dim_separator
fi

if [ -s "${remote_branches_file}" ]; then
    echo
    dim_separator
    printf "${YELLOW}  other remote branches${RESET}\n"
    dim_separator
    cat "${remote_branches_file}"
    dim_separator
fi

echo
success "Done."
