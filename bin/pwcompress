#!/bin/bash

set -e

source "$(dirname "${BASH_SOURCE[0]}")/shelllog.sh"
source "$(dirname "${BASH_SOURCE[0]}")/7zpw.sh"

usage() {
    cat << EOF
Usage: $(basename "${0}") [-c LEVEL] [-p PASSWORD] [-h] <file1> [file2 ...]

Creates a password-protected, header-encrypted 7z archive.
Password is never passed as a command-line argument - fed via expect.

Options:
  -c LEVEL    Compression level 0-9 (default: 5)
  -p PASSWORD Password (default: \$PASSWORD_ZIPS from keyguard)
  -h          Show this help

Environment:
  PASSWORD_ZIPS  Archive password (loaded via envify)

Archive naming:
  Single input  -> strips extension, adds .7z  (report.pdf -> report.7z)
  Multiple      -> parent directory name + .7z  (src/a src/b -> src.7z)

Examples:
  $(basename "${0}") report.pdf
  $(basename "${0}") -c 0 BigFolder/
  $(basename "${0}") -p mypass file1.txt file2.txt
EOF
    exit "${1:-1}"
}

COMPRESSION_LEVEL=5
PASSWORD=""

while getopts ":c:p:h" opt; do
    case $opt in
        h)
            usage 0
            ;;
        c)
            COMPRESSION_LEVEL=$OPTARG
            if ! [[ $COMPRESSION_LEVEL =~ ^[0-9]$ ]]; then
                error "Compression level must be a number between 0 and 9."
                exit 1
            fi
            ;;
        p)
            PASSWORD=$OPTARG
            ;;
        \?)
            error "Invalid option: -$OPTARG"
            usage
            ;;
        :)
            error "Option -$OPTARG requires an argument."
            usage
            ;;
    esac
done

shift $((OPTIND-1))
if [ "$#" -lt 1 ]; then
    usage
fi

if [ -z "$PASSWORD" ]; then
    source envify PASSWORD_ZIPS
    PASSWORD="$PASSWORD_ZIPS"
fi

if [ "$#" -eq 1 ]; then
    ARCHIVE_NAME="${1%.*}.7z"
else
    ARCHIVE_NAME="$(basename "$(dirname "$1")").7z"
fi

log "Archive creation in progress, please wait... (compression level $COMPRESSION_LEVEL)"
_7zpw_run 2 "$PASSWORD" a -mx="$COMPRESSION_LEVEL" -p -mhe=on "$ARCHIVE_NAME" "$@"
success "Archive $ARCHIVE_NAME created successfully with compression level $COMPRESSION_LEVEL!"
