#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/shelllog.sh"
source envify PASSWORD_ZIPS

show_usage() {
    cat << EOF
Usage: $(basename "$0") [-o OUTPUT_DIR] <archive-file>

Extracts password-protected archive using \$PASSWORD_ZIPS.

Destination resolution:
  1. -o OUTPUT_DIR       - explicit destination (wins)
  2. archive in \$DESKDIR - extract to \$DESKDIR
  3. otherwise           - prompt via gum (archive dir, current dir, \$DESKDIR)

Environment variables required:
  DESKDIR         - Desktop directory (fallback destination)
  PASSWORD_ZIPS   - Password for the archive
  GLOBAL_ENV_FILE - (optional) File to source for environment variables

Examples:
  $(basename "$0") archive.7z
  $(basename "$0") -o /tmp/out archive.7z
  $(basename "$0") /path/to/archive.7z
EOF
}

OUTPUT_DIR=""
while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help)
            show_usage
            exit 0
            ;;
        -o)
            if [ -z "${2:-}" ]; then
                error "-o requires a directory argument"
                exit 1
            fi
            OUTPUT_DIR="$2"
            shift 2
            ;;
        *)
            break
            ;;
    esac
done

if [ $# -eq 0 ]; then
    show_usage
    exit 1
fi

ARCHIVE="$1"

if [ ! -f "$ARCHIVE" ]; then
    error "Archive not found: $ARCHIVE"
    exit 1
fi

if ! command -v 7z &> /dev/null; then
    error "7z command not found. Please install p7zip"
    exit 1
fi

if [ -n "${GLOBAL_ENV_FILE:-}" ] && [ -f "$GLOBAL_ENV_FILE" ]; then
    info "Loading environment from $GLOBAL_ENV_FILE"
    source "$GLOBAL_ENV_FILE"
fi

if [ -z "${DESKDIR:-}" ]; then
    error "DESKDIR environment variable not set"
    exit 1
fi

if [ -z "${PASSWORD_ZIPS:-}" ]; then
    error "PASSWORD_ZIPS environment variable not set"
    exit 1
fi

ARCHIVE_DIR="$(cd "$(dirname "$ARCHIVE")" && pwd)"
DESKDIR_ABS="$(cd "$DESKDIR" && pwd)"

if [ -n "$OUTPUT_DIR" ]; then
    DEST="$OUTPUT_DIR"
elif [ "$ARCHIVE_DIR" = "$DESKDIR_ABS" ]; then
    DEST="$DESKDIR"
else
    CWD="$(pwd)"
    if ! command -v gum >/dev/null 2>&1; then
        error "gum not found; pass -o OUTPUT_DIR explicitly"
        exit 1
    fi
    options=("Archive directory ($ARCHIVE_DIR)")
    [ "$CWD" != "$ARCHIVE_DIR" ] && options+=("Current directory ($CWD)")
    [ "$DESKDIR_ABS" != "$ARCHIVE_DIR" ] && [ "$DESKDIR_ABS" != "$CWD" ] && options+=("Desktop ($DESKDIR)")
    choice=$(gum choose --header "Extract destination:" "${options[@]}")
    case "$choice" in
        "Archive directory"*) DEST="$ARCHIVE_DIR" ;;
        "Current directory"*) DEST="$CWD" ;;
        "Desktop"*) DEST="$DESKDIR" ;;
        *)
            error "No destination selected"
            exit 1
            ;;
    esac
fi

mkdir -p "$DEST"

log "Extracting archive: $ARCHIVE"
log "Destination: $DEST"

if 7z x "$ARCHIVE" -o"$DEST" -p"$PASSWORD_ZIPS"; then
    success "Archive extracted successfully"
else
    error "Extraction failed"
    exit 1
fi
