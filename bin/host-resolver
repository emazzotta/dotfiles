#!/usr/bin/env python3
from __future__ import annotations

import argparse
import platform
import queue
import subprocess
import sys
import threading
import time
from collections.abc import Iterator
from typing import Final

RESOLVE_TIMEOUT_MS: Final = 150
IS_DARWIN: Final = platform.system() == "Darwin"
HOSTS: Final[dict[str, tuple[str, ...]]] = {
    "ci-macmini": ("ci-macmini.dyn.leonardo.local", "Mac-mini-von-Andreas.local"),
}


def resolve_ips(hostname: str, timeout_ms: float, dns_server: str | None = None) -> tuple[str, ...]:
    try:
        if dns_server:
            timeout_sec = str(max(1, int(timeout_ms / 1000)))
            result = subprocess.run(
                ["dig", "+short", "+time=" + timeout_sec, "+tries=1", f"@{dns_server}",
                 hostname, "AAAA", hostname, "A"],
                capture_output=True,
                timeout=timeout_ms / 1000,
            )
            if result.returncode != 0:
                return ()
            return tuple(line for line in result.stdout.decode().strip().splitlines() if line)
        result = subprocess.run(
            [sys.executable, "-c",
             "import socket,sys; "
             "print('\\n'.join(dict.fromkeys(i[4][0] for i in socket.getaddrinfo(sys.argv[1], None))))",
             hostname],
            capture_output=True,
            timeout=timeout_ms / 1000,
        )
        if result.returncode != 0:
            return ()
        return tuple(line for line in result.stdout.decode().strip().splitlines() if line)
    except (subprocess.TimeoutExpired, OSError):
        return ()


def ping_ip(ip: str, timeout_ms: float) -> bool:
    is_v6 = ":" in ip
    if IS_DARWIN:
        cmd = ["ping6" if is_v6 else "ping", "-c", "1", "-W", str(int(timeout_ms)), ip]
    else:
        cmd = ["ping", "-6" if is_v6 else "-4", "-c", "1",
               "-W", str(max(1, int(timeout_ms) // 1000)), ip]
    try:
        return subprocess.run(cmd, capture_output=True).returncode == 0
    except OSError:
        return False


def try_host(hostname: str, timeout_ms: float, dns_server: str | None = None, silent: bool = False) -> str | None:
    for ip in resolve_ips(hostname, timeout_ms, dns_server):
        if ping_ip(ip, timeout_ms):
            if not silent:
                print(f"Resolved {hostname} -> {ip}", file=sys.stderr)
            return ip
    return None


def enforce_timeout(q: queue.Queue[str | None], count: int, timeout_ms: float) -> Iterator[str | None]:
    deadline = time.monotonic() + timeout_ms / 1000
    for _ in range(count):
        remaining = deadline - time.monotonic()
        if remaining <= 0:
            return
        try:
            yield q.get(timeout=remaining)
        except queue.Empty:
            return


def fetch_first_reachable(hostnames: tuple[str, ...], timeout_ms: float, dns_server: str | None = None,
                          silent: bool = False) -> str | None:
    results: queue.Queue[str | None] = queue.Queue()
    for hostname in hostnames:
        threading.Thread(target=lambda h=hostname: results.put(try_host(h, timeout_ms, dns_server, silent)), daemon=True).start()
    return next((ip for ip in enforce_timeout(results, len(hostnames), timeout_ms) if ip), None)


def resolve_hosts(short_name: str, timeout_ms: float, fallback_ip: str | None = None,
                   dns_server: str | None = None, silent: bool = False) -> str:
    hostnames = HOSTS.get(short_name, (short_name,))
    if ip := fetch_first_reachable(hostnames, timeout_ms, dns_server, silent):
        return ip
    fallback_ip = fallback_ip or "127.0.0.1"
    if not silent:
        print(f"No reachable host found for {short_name}, falling back to {fallback_ip}", file=sys.stderr)
    return fallback_ip


def main() -> None:
    parser = argparse.ArgumentParser(
        description=(
            "Resolve a host to a reachable IPv4 or IPv6 address. "
            "Queries both A and AAAA records, pings each result, and returns "
            "the first one that answers. IPv6 is preferred when both work."
        ),
        epilog=(
            "examples:\n"
            "  # built-in short name from the HOSTS map\n"
            "  host-resolver ci-macmini\n"
            "\n"
            "  # arbitrary hostname via system resolver (returns v4 or v6)\n"
            "  host-resolver one.one.one.one\n"
            "\n"
            "  # v6-only host - returns an AAAA address\n"
            "  host-resolver ipv6.google.com\n"
            "\n"
            "  # query a specific DNS server, longer timeout\n"
            "  host-resolver myhost -d 192.168.0.254 -t 500\n"
            "\n"
            "  # v6 fallback when unreachable\n"
            "  host-resolver myhost -f ::1 -s\n"
            "\n"
            "  # exit 1 when unreachable (fell back), useful for scripting\n"
            "  host-resolver myhost -d 192.168.0.254 -a -s && echo 'up' || echo 'down'\n"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("host",
                        help="short name from the built-in HOSTS map, or any hostname/IP (v4 or v6) to resolve directly")
    parser.add_argument("-t", "--timeout", type=float, default=RESOLVE_TIMEOUT_MS, metavar="MS",
                        help=f"per-address resolution and ping timeout in milliseconds (default: {RESOLVE_TIMEOUT_MS})")
    parser.add_argument("-f", "--fallback-ip", default=None, metavar="IP",
                        help="IPv4 or IPv6 address to return when the host is unreachable (default: 127.0.0.1)")
    parser.add_argument("-d", "--dns", default=None, metavar="SERVER",
                        help="DNS server to query via dig instead of the system resolver; queries both AAAA and A")
    parser.add_argument("-s", "--silent", action="store_true",
                        help="suppress all diagnostic output on stderr")
    parser.add_argument("-a", "--alert", action="store_true",
                        help="exit 1 when the host resolved to an IP different from the fallback")
    args = parser.parse_args()
    ip = resolve_hosts(args.host, args.timeout, fallback_ip=args.fallback_ip, dns_server=args.dns, silent=args.silent)
    print(ip)
    if args.alert and ip != (args.fallback_ip or "127.0.0.1"):
        sys.exit(1)


if __name__ == "__main__":
    main()
