#!/bin/bash
set -euo pipefail

PROJECTS_DIR="${CLAUDE_PROJECTS:-${HOME}/.claude/projects}"

show_usage() {
    cat << EOF
Usage: $(basename "$0") [-n COUNT] [-a] [-y] [SEARCH]

Interactive session picker for removing Claude Code sessions. Multi-select
with gum; deletes .jsonl files and matching state directories.

Options:
  -n COUNT   Number of sessions to show (default: all)
  -a         All projects (default: only current project slug)
  -m         Multi-select (space to toggle, enter to confirm)
  -y         Skip confirmation prompt
  -h         Show this help

Arguments:
  SEARCH     Optional text to filter by first user message

Environment:
  CLAUDE_PROJECTS   Path to projects dir (default: ~/.claude/projects)
EOF
}

path_to_slug() {
    local p="$1"
    echo "${p//\//-}"
}

fetch_sessions() {
    local count="$1" search="$2" all="$3"
    [ -d "$PROJECTS_DIR" ] || { echo "Error: projects dir not found at $PROJECTS_DIR" >&2; return 1; }

    local scope
    if [ "$all" = true ]; then
        scope="$PROJECTS_DIR"
    else
        local slug
        slug=$(path_to_slug "$(pwd)")
        if [ -d "$PROJECTS_DIR/$slug" ]; then
            scope="$PROJECTS_DIR/$slug"
        else
            echo "No sessions for current project ($slug). Use -a for all projects." >&2
            return 1
        fi
    fi

    python3 - "$scope" "$count" "$search" "$all" << 'PY'
import json, sys, pathlib
scope, count, search, all_projects = sys.argv[1], int(sys.argv[2]), sys.argv[3].lower(), sys.argv[4] == 'true'
if all_projects:
    jsonls = [j for p in pathlib.Path(scope).iterdir() if p.is_dir() for j in p.glob('*.jsonl')]
else:
    jsonls = list(pathlib.Path(scope).glob('*.jsonl'))
rows = []
for jsonl in jsonls:
    try:
        mtime = jsonl.stat().st_mtime
        first_msg = ''
        with jsonl.open() as f:
            for line in f:
                try:
                    d = json.loads(line)
                except Exception:
                    continue
                if d.get('type') == 'user' and isinstance(d.get('message'), dict):
                    content = d['message'].get('content', '')
                    if isinstance(content, list):
                        content = ' '.join(p.get('text','') for p in content if isinstance(p, dict))
                    first_msg = str(content).strip().replace('\n',' ').replace('\t',' ')
                    break
        if search and search not in first_msg.lower() and search not in jsonl.stem.lower():
            continue
        rows.append({'id': jsonl.stem, 'path': str(jsonl), 'project': jsonl.parent.name, 'msg': first_msg, 'mtime': mtime})
    except Exception:
        continue
rows.sort(key=lambda r: r['mtime'], reverse=True)
print(json.dumps(rows[:count]))
PY
}

format_choices() {
    python3 -c "
import json, sys, time
now = time.time()
for s in json.loads(sys.stdin.read()):
    title = s['msg'] or '(no prompt)'
    if len(title) > 50: title = title[:47] + '...'
    diff = int(now - s['mtime'])
    if diff < 60: ago = 'just now'
    elif diff < 3600: ago = f'{diff // 60}m ago'
    elif diff < 86400: ago = f'{diff // 3600}h ago'
    else:
        d = diff // 86400
        ago = 'yesterday' if d == 1 else (f'{d}d ago' if d < 30 else f'{d // 30}mo ago')
    print(f\"{s['path']}\\t{title}\\t{ago}\\t{s['project']}\")
"
}

main() {
    local count=100000 skip_confirm=false all=false multi=false search=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help) show_usage; exit 0 ;;
            -n) count="$2"; shift 2 ;;
            -a) all=true; shift ;;
            -m) multi=true; shift ;;
            -y) skip_confirm=true; shift ;;
            -*) echo "Unknown option: $1" >&2; show_usage >&2; exit 1 ;;
            *) search="$1"; shift ;;
        esac
    done

    local json
    json=$(fetch_sessions "$count" "$search" "$all") || exit 1
    if [ -z "$json" ] || [ "$json" = "[]" ]; then
        echo "No sessions found${search:+ matching '$search'}" >&2
        exit 1
    fi

    local choices display
    choices=$(echo "$json" | format_choices)
    display=$(echo "$choices" | while IFS=$'\t' read -r path title ago project; do
        printf "%-52s %-12s %-30s %s\n" "$title" "$ago" "$project" "$path"
    done)

    local picker_args=(--header "Select session to DELETE:")
    [ "$multi" = true ] && picker_args=(--multi --header "Select session(s) to DELETE (tab=toggle, enter=confirm):")

    local selected
    selected=$(echo "$display" | picker "${picker_args[@]}") || exit 1
    [ -n "$selected" ] || { echo "No selection" >&2; exit 1; }

    local paths=()
    while IFS= read -r line; do
        paths+=("$(echo "$line" | awk '{print $NF}')")
    done <<< "$selected"

    echo "About to delete ${#paths[@]} session(s):"
    echo "$selected" | sed 's/^/  /'

    if [ "$skip_confirm" = false ]; then
        gum confirm "Delete?" || { echo "Cancelled" >&2; exit 1; }
    fi

    for p in "${paths[@]}"; do
        local dir="${p%.jsonl}"
        rm -f "$p"
        [ -d "$dir" ] && rm -rf "$dir"
    done
    echo "Deleted ${#paths[@]} session(s)."
}

main "$@"
