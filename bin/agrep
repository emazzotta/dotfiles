#!/usr/bin/env python3
"""Search shell aliases, exports, function definitions, and custom bin scripts."""

import argparse
import os
import re
import shutil
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Iterable

BOLD = "\033[1m"
DIM = "\033[2m"
RED = "\033[1;31m"
RESET = "\033[0m"

HOME = Path.home()
BASHRC_DIR = next(
    (d for d in (HOME / ".bashrc.d", HOME / "dotfiles" / "bash" / ".bashrc.d") if d.is_dir()),
    None,
)
BIN_DIR = Path(os.environ.get("CUSTOM_BIN_DIR", HOME / "dotfiles" / "bin"))

DEF_LINE_RE = re.compile(r"^(alias |export |[A-Za-z_][A-Za-z0-9_]*\(\))")


@dataclass
class Hit:
    path: Path
    line_no: int | None
    text: str


def colorize(text: str, term: str, exact: bool) -> str:
    pat = rf"\b{re.escape(term)}\b" if exact else re.escape(term)
    return re.sub(pat, lambda m: f"{RED}{m.group(0)}{RESET}", text, flags=re.IGNORECASE)


def rg_content(term: str, path: Path, exact: bool) -> list[Hit]:
    if not path.is_dir():
        return []
    args = ["rg", "--no-heading", "--with-filename", "--line-number", "--color=never", "-F", "-i"]
    if exact:
        args.append("-w")
    args += ["--", term, str(path)]
    r = subprocess.run(args, capture_output=True, text=True)
    hits = []
    for line in r.stdout.splitlines():
        parts = line.split(":", 2)
        if len(parts) < 3:
            continue
        fp, ln, text = parts
        try:
            hits.append(Hit(Path(fp), int(ln), text))
        except ValueError:
            continue
    return hits


def filename_matches(term: str, path: Path, exact: bool) -> list[Path]:
    if not path.is_dir():
        return []
    pat = re.compile(
        rf"(?i)\b{re.escape(term)}\b" if exact else rf"(?i){re.escape(term)}"
    )
    return [p for p in sorted(path.iterdir()) if p.is_file() and pat.search(p.name)]


def bashrc_matches(term: str, exact: bool) -> list[Hit]:
    if BASHRC_DIR is None:
        return []
    t = term.lower()
    hits = []
    pat = re.compile(rf"(?i)\b{re.escape(term)}\b") if exact else None
    for p in sorted(BASHRC_DIR.glob("[0-9]*.sh")):
        try:
            for i, raw in enumerate(p.read_text().splitlines(), 1):
                if not DEF_LINE_RE.match(raw):
                    continue
                if pat:
                    if not pat.search(raw):
                        continue
                elif t not in raw.lower():
                    continue
                hits.append(Hit(p, i, raw))
        except OSError:
            continue
    return hits


def print_section(title: str, lines: Iterable[str]) -> bool:
    lines = list(lines)
    if not lines:
        return False
    print(f"\n{BOLD}[{title}]{RESET}")
    for line in lines:
        print(line)
    return True


def fmt_hit(h: Hit, base: Path, term: str, exact: bool) -> str:
    rel = h.path.relative_to(base) if h.path.is_relative_to(base) else h.path
    return f"{rel}:{h.line_no}:{colorize(h.text, term, exact)}"


def run_picker(candidates: list[str], header: str) -> str | None:
    if not shutil.which("picker"):
        return None
    r = subprocess.run(
        ["picker", "--header", header],
        input="\n".join(candidates),
        capture_output=True,
        text=True,
    )
    sel = r.stdout.strip()
    return sel or None


def view_bin_script(name: str) -> None:
    path = BIN_DIR / name
    if not path.is_file():
        print(f"not a bin script: {name}", file=sys.stderr)
        return
    editor = os.environ.get("EDITOR") or shutil.which("vim") or shutil.which("vi")
    if sys.stdout.isatty() and editor:
        subprocess.run([editor, str(path)])
    else:
        sys.stdout.write(f"{BOLD}--- {name} ---{RESET}\n")
        sys.stdout.write(path.read_text(errors="replace"))


def offer_view(candidates: list[str]) -> None:
    if not candidates or not (sys.stdin.isatty() and sys.stdout.isatty()):
        return
    if not shutil.which("gum"):
        return

    count = len(candidates)
    prompt = (
        f"View full content of bin script '{candidates[0]}'?"
        if count == 1
        else f"View full content of one of the {count} matching bin scripts?"
    )
    if subprocess.run(["gum", "confirm", prompt, "--default=true"]).returncode != 0:
        return

    choice = candidates[0] if count == 1 else run_picker(candidates, "View full script (esc to skip):")
    if not choice:
        return
    print()
    view_bin_script(choice)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("-e", "--exact", action="store_true", help="match whole words only")
    parser.add_argument("term")
    args = parser.parse_args()

    term, exact = args.term, args.exact

    bashrc_hits = bashrc_matches(term, exact)
    if BASHRC_DIR is not None:
        lines = [fmt_hit(h, BASHRC_DIR, term, exact) for h in bashrc_hits]
        print_section("config", lines)

    bin_content_hits = rg_content(term, BIN_DIR, exact)
    name_hits = filename_matches(term, BIN_DIR, exact)

    content_files = {h.path for h in bin_content_hits}
    bin_lines = [fmt_hit(h, BIN_DIR, term, exact) for h in bin_content_hits]
    for p in name_hits:
        if p not in content_files:
            bin_lines.append(f"{DIM}{colorize(p.name, term, exact)}{RESET} (filename match)")
    printed_bin = print_section("bin", bin_lines)

    candidates: list[str] = []
    seen: set[str] = set()
    exact_name = BIN_DIR / term
    if exact_name.is_file() and term not in seen:
        candidates.append(term)
        seen.add(term)
    for p in name_hits:
        if p.name not in seen:
            candidates.append(p.name)
            seen.add(p.name)
    for p in bin_content_hits:
        if p.path.name not in seen:
            candidates.append(p.path.name)
            seen.add(p.path.name)

    if printed_bin:
        offer_view(candidates)
    return 0


if __name__ == "__main__":
    sys.exit(main())
