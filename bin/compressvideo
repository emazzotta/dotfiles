#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=shelllog.sh
source "${SCRIPT_DIR}/shelllog.sh"

readonly VALID_PRESETS="ultrafast superfast veryfast faster fast medium slow slower veryslow placebo"

codec=h265
quality=""
preset=slow
scale=""
scale_height=""
fps_target=""
fps_half=no
computed_fps=""
use_hw=no
tonemap=no
copy_audio=no
remove=no
just_preview_compatible=no
dry_run=no

input_file=""
output_file=""
av1enc=""
is_hdr=no
is_10bit=no
src_pix_fmt=""
src_transfer=""
src_primaries=""
src_space=""
src_fps_num=""
src_fps_den=""

cmd=()
enc_args=()
color_args=()

print_help() {
    log "usage: $(basename "${0}") [options] <video_file>"
    log
    log "Compress (and optionally rescale) a video with ffmpeg. Default: h265, preset slow."
    log
    log "options:"
    log "  -c, --codec <h264|h265|av1>      Video codec (default: ${codec})"
    log "  -q, --quality <n>                CRF for software encode, lower = better/bigger"
    log "                                   (defaults: h264 23, h265 28, av1 32)."
    log "                                   With hardware encode this is videotoolbox -q:v (higher = better, default 55)."
    log "  -p, --preset <name>              x264/x265 preset ultrafast..placebo (default: ${preset}). Ignored for av1 and hardware encode."
    log "  -s, --scale <2160p|1080p|720p|N> Downscale to a max height (never upscales)."
    log "  --fps <n>                        Re-time to N fps by dropping/duplicating frames (e.g. 24, 25, 30)."
    log "  --fps-half                       Halve the frame rate: exact 2:1 frame drop, no blending (60->30, 30->15)."
    log "  --hw                             Hardware encode (videotoolbox, Apple Silicon): far faster, larger files."
    log "  --tonemap                        Tonemap HDR (HLG/PQ) footage to SDR Rec.709."
    log "  --copy-audio                     Copy the audio stream instead of re-encoding to AAC 128k."
    log "  --just-preview-compatible        Force h264 8-bit for macOS Quicktime/Preview compatibility."
    log "  --rm-original                    Delete the source file after a successful compress."
    log "  --dry-run                        Print the ffmpeg command without running it."
    log "  -h, --help                       Show this help."
}

die() {
    error "$*"
    exit 2
}

default_crf() {
    case "$1" in
        h264) printf 23 ;;
        h265) printf 28 ;;
        av1)  printf 32 ;;
    esac
}

resolve_scale() {
    case "$1" in
        2160p|4k|4K|uhd) printf 2160 ;;
        1440p|2k)        printf 1440 ;;
        1080p|fhd)       printf 1080 ;;
        720p|hd)         printf 720 ;;
        480p)            printf 480 ;;
        360p)            printf 360 ;;
        *[!0-9]*|'')     return 1 ;;
        *)               printf '%s' "$1" ;;
    esac
}

human_size() {
    awk -v b="$1" 'BEGIN {
        split("B KB MB GB TB", u, " ")
        i = 1; s = b
        while (s >= 1024 && i < 5) { s /= 1024; i++ }
        printf "%.1f %s", s, u[i]
    }'
}

reduction_pct() {
    awk -v a="$1" -v b="$2" 'BEGIN { if (a > 0) printf "%.1f", (1 - b / a) * 100; else printf "0.0" }'
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) print_help; exit 0 ;;
            -q|--quality) [[ $# -ge 2 ]] || die "--quality requires a value"; quality="$2"; shift 2 ;;
            -c|--codec) [[ $# -ge 2 ]] || die "--codec requires a value"; codec="$2"; shift 2 ;;
            -p|--preset) [[ $# -ge 2 ]] || die "--preset requires a value"; preset="$2"; shift 2 ;;
            -s|--scale) [[ $# -ge 2 ]] || die "--scale requires a value"; scale="$2"; shift 2 ;;
            --fps) [[ $# -ge 2 ]] || die "--fps requires a value"; fps_target="$2"; shift 2 ;;
            --fps-half) fps_half=yes; shift ;;
            --hw) use_hw=yes; shift ;;
            --tonemap) tonemap=yes; shift ;;
            --copy-audio) copy_audio=yes; shift ;;
            --rm-original) remove=yes; shift ;;
            --just-preview-compatible) just_preview_compatible=yes; shift ;;
            --dry-run) dry_run=yes; shift ;;
            --) shift; break ;;
            -*) die "unknown option: $1" ;;
            *)
                if [[ -z "${input_file}" ]]; then
                    input_file="$1"
                else
                    die "unexpected extra argument: $1"
                fi
                shift
                ;;
        esac
    done
    if [[ -z "${input_file}" && $# -gt 0 ]]; then
        input_file="$1"
    fi
}

normalize_and_validate() {
    if [[ -z "${input_file}" ]]; then
        print_help
        exit 2
    fi
    if [[ ! -f "${input_file}" ]]; then
        die "input file not found: '${input_file}'"
    fi

    if [[ "${just_preview_compatible}" == yes ]]; then
        codec=h264
        use_hw=no
        tonemap=no
    fi

    case "${codec}" in
        h264|h265|av1) : ;;
        *) die "invalid codec '${codec}' (use h264, h265 or av1)" ;;
    esac

    if [[ "${use_hw}" == yes && "${codec}" == av1 ]]; then
        die "hardware av1 encode is unavailable via videotoolbox; drop --hw or pick h264/h265"
    fi

    if [[ "${use_hw}" == no && "${codec}" != av1 ]]; then
        case " ${VALID_PRESETS} " in
            *" ${preset} "*) : ;;
            *) die "invalid --preset '${preset}' (valid: ${VALID_PRESETS})" ;;
        esac
    fi

    if [[ -n "${scale}" ]]; then
        scale_height="$(resolve_scale "${scale}")" \
            || die "invalid --scale '${scale}' (use 2160p/1440p/1080p/720p/480p or a height in px)"
    fi

    if [[ "${fps_half}" == yes && -n "${fps_target}" ]]; then
        die "--fps and --fps-half are mutually exclusive"
    fi
    if [[ -n "${fps_target}" && ! "${fps_target}" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
        die "invalid --fps '${fps_target}' (use a positive number like 24, 25, 30)"
    fi

    if [[ -z "${quality}" ]]; then
        if [[ "${use_hw}" == yes ]]; then
            quality=55
        else
            quality="$(default_crf "${codec}")"
        fi
    fi

    output_file="${input_file%.*}_compressed.mp4"
    if [[ -e "${output_file}" ]]; then
        die "output already exists: '${output_file}'"
    fi
}

require_cmds() {
    local missing=()
    local c
    for c in "$@"; do
        command -v "$c" >/dev/null 2>&1 || missing+=("$c")
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        die "missing required command(s): ${missing[*]}"
    fi
}

require_tonemap_support() {
    if ! ffmpeg -hide_banner -filters 2>/dev/null | grep -q 'zscale'; then
        die "--tonemap needs an ffmpeg built with zscale (libzimg); this build lacks it"
    fi
}

select_av1_encoder() {
    if ffmpeg -hide_banner -encoders 2>/dev/null | grep -q 'libsvtav1'; then
        av1enc=libsvtav1
    else
        av1enc=libaom-av1
        warn "libsvtav1 not found; falling back to the much slower libaom-av1"
    fi
}

probe_field() {
    ffprobe -v error -select_streams v:0 \
        -show_entries "stream=$1" -of default=noprint_wrappers=1:nokey=1 "${input_file}" 2>/dev/null
}

detect_source() {
    src_pix_fmt="$(probe_field pix_fmt)"
    src_transfer="$(probe_field color_transfer)"
    src_primaries="$(probe_field color_primaries)"
    src_space="$(probe_field color_space)"

    local rfr
    rfr="$(probe_field r_frame_rate)"
    if [[ "${rfr}" == */* ]]; then
        src_fps_num="${rfr%%/*}"
        src_fps_den="${rfr##*/}"
    fi

    case "${src_transfer}" in
        smpte2084|arib-std-b67) is_hdr=yes ;;
        *) is_hdr=no ;;
    esac
    case "${src_pix_fmt}" in
        *10le|*10be|p010*) is_10bit=yes ;;
        *) is_10bit=no ;;
    esac
}

resolve_fps() {
    if [[ "${fps_half}" == yes ]]; then
        if [[ ! "${src_fps_num}" =~ ^[0-9]+$ || ! "${src_fps_den}" =~ ^[0-9]+$ || "${src_fps_num}" == 0 ]]; then
            die "--fps-half needs a detectable source frame rate; ffprobe reported '${src_fps_num:-?}/${src_fps_den:-?}'"
        fi
        computed_fps="${src_fps_num}/$(( src_fps_den * 2 ))"
    elif [[ -n "${fps_target}" ]]; then
        computed_fps="${fps_target}"
    fi
}

build_video_filter() {
    local filters=()
    if [[ "${tonemap}" == yes ]]; then
        filters+=("zscale=t=linear:npl=100,format=gbrpf32le,zscale=p=bt709,tonemap=tonemap=hable:desat=0,zscale=t=bt709:m=bt709:r=tv,format=yuv420p")
    fi
    if [[ -n "${computed_fps}" ]]; then
        filters+=("fps=${computed_fps}")
    fi
    if [[ -n "${scale_height}" ]]; then
        filters+=("scale=-2:min(ih\\,${scale_height})")
    fi
    if [[ ${#filters[@]} -eq 0 ]]; then
        return 0
    fi
    local IFS=,
    printf '%s' "${filters[*]}"
}

append_meta() {
    if [[ -n "$2" && "$2" != unknown && "$2" != "N/A" ]]; then
        color_args+=("$1" "$2")
    fi
}

build_encoder_args() {
    if [[ "${use_hw}" == yes ]]; then
        case "${codec}" in
            h264) enc_args=(-c:v h264_videotoolbox -q:v "${quality}") ;;
            h265) enc_args=(-c:v hevc_videotoolbox -q:v "${quality}" -tag:v hvc1) ;;
        esac
        return 0
    fi
    case "${codec}" in
        h264) enc_args=(-c:v libx264 -preset "${preset}" -crf "${quality}") ;;
        h265) enc_args=(-c:v libx265 -preset "${preset}" -crf "${quality}" -tag:v hvc1) ;;
        av1)
            if [[ "${av1enc}" == libsvtav1 ]]; then
                enc_args=(-c:v libsvtav1 -crf "${quality}" -preset 6)
            else
                enc_args=(-c:v libaom-av1 -crf "${quality}" -b:v 0 -cpu-used 4 -row-mt 1)
            fi
            ;;
    esac
}

build_color_args() {
    color_args=()
    if [[ "${tonemap}" == yes ]]; then
        color_args=(-color_primaries bt709 -color_trc bt709 -colorspace bt709)
        return 0
    fi
    if [[ "${use_hw}" == yes ]]; then
        return 0
    fi
    case "${codec}" in
        h264)
            color_args=(-pix_fmt yuv420p)
            ;;
        h265|av1)
            if [[ "${is_10bit}" == yes || "${is_hdr}" == yes ]]; then
                color_args=(-pix_fmt yuv420p10le)
                append_meta -color_primaries "${src_primaries}"
                append_meta -color_trc "${src_transfer}"
                append_meta -colorspace "${src_space}"
            fi
            ;;
    esac
}

warn_hdr() {
    if [[ "${is_hdr}" != yes || "${tonemap}" == yes ]]; then
        return 0
    fi
    if [[ "${codec}" == h264 ]]; then
        warn "source is HDR but h264 carries HDR poorly; colours may wash out. Consider --tonemap or -c h265."
    elif [[ "${use_hw}" == yes ]]; then
        warn "hardware encode may not preserve HDR metadata cleanly; consider software or --tonemap."
    fi
}

build_command() {
    local vf
    vf="$(build_video_filter)"
    build_encoder_args
    build_color_args
    warn_hdr

    cmd=(ffmpeg -hide_banner -y -i "${input_file}")
    if [[ -n "${vf}" ]]; then
        cmd+=(-vf "${vf}")
    fi
    cmd+=("${enc_args[@]}")
    if [[ ${#color_args[@]} -gt 0 ]]; then
        cmd+=("${color_args[@]}")
    fi
    if [[ "${copy_audio}" == yes ]]; then
        cmd+=(-c:a copy)
    else
        cmd+=(-c:a aac -b:a 128k)
    fi
    cmd+=(-movflags +faststart "${output_file}")
}

cleanup_partial() {
    if [[ "${encoding:-no}" == yes && -f "${output_file}" ]]; then
        /bin/rm -f "${output_file}"
        warn "removed incomplete output '${output_file}'"
    fi
}

report_result() {
    local in_b out_b
    in_b="$(wc -c < "${input_file}")"
    out_b="$(wc -c < "${output_file}")"
    success "done: $(human_size "${in_b}") -> $(human_size "${out_b}") ($(reduction_pct "${in_b}" "${out_b}")% smaller)"
    if [[ "${remove}" == yes ]]; then
        /bin/rm -f "${input_file}"
        log "removed original '${input_file}'"
    fi
}

encoding=no

run_compression() {
    log "compressing '${input_file}' -> '${output_file}'"
    encoding=yes
    if "${cmd[@]}"; then
        encoding=no
        report_result
    else
        local code=$?
        encoding=no
        cleanup_partial
        die "ffmpeg failed (exit ${code})"
    fi
}

main() {
    parse_args "$@"
    normalize_and_validate
    require_cmds ffmpeg ffprobe
    if [[ "${tonemap}" == yes ]]; then
        require_tonemap_support
    fi
    if [[ "${codec}" == av1 && "${use_hw}" == no ]]; then
        select_av1_encoder
    fi
    detect_source
    resolve_fps
    build_command

    if [[ "${dry_run}" == yes ]]; then
        info "dry run - would execute:"
        printf '%s ' "${cmd[@]}"
        printf '\n'
        exit 0
    fi

    log "codec=${codec} quality=${quality} preset=${preset} scale=${scale:-none} fps=${computed_fps:-source} hw=${use_hw} tonemap=${tonemap} hdr=${is_hdr}"
    trap 'echo; warn "interrupted"; cleanup_partial; exit 130' INT TERM
    run_compression
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
