#!/bin/bash

set -e

source "$(dirname "$0")/shelllog.sh"

output_filename="merged"
output_format="wav"
attach=0

show_help() {
    log "Merge multiple audio files into a single audio file and convert it to the specified format."
    log ""
    log "Usage: $(basename "$0") [-o <output_filename>] [-f <format>] <audio files...>"
    log "       $(basename "$0") -a [-o <output_filename>] <audio files...>"
    log ""
    log "Options:"
    log "  -o, --output FILENAME    Specify the output file name (default is 'merged.wav')."
    log "  -f, --format FORMAT      Specify the audio format (e.g., mp3, ogg) after merging."
    log "  -a, --attach             Byte-concatenate the files as-is (no re-encoding)."
    log "                           Output size equals the sum of the inputs. Same-format inputs"
    log "                           only (e.g. mp3+mp3); the output keeps the first file's extension."
    log ""
    log "<audio files...>    Space-separated list of audio files to merge."
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -o|--output)
            output_filename="$2"
            output_filename="${output_filename%.*}"
            shift
            shift
            ;;
        -f|--format)
            output_format="$2"
            shift
            shift
            ;;
        -a|--attach)
            attach=1
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            break
            ;;
    esac
done

if [ $# -eq 0 ]; then
    error "No audio files specified."
    show_help
    exit 1
fi

if [ "$attach" -eq 1 ]; then
    first_ext="${1##*.}"
    attach_output="${output_filename}.${first_ext}"
    for file in "$@"; do
        if [ ! -f "$file" ]; then
            error "File '$file' not found."
            exit 1
        fi
        if [ "$file" -ef "$attach_output" ] 2>/dev/null; then
            error "Input '$file' is the same file as the output '$attach_output'; aborting to avoid clobbering."
            exit 1
        fi
    done
    cat -- "$@" > "$attach_output"
    success "Attached $# file(s) into '$attach_output' ($(du -h "$attach_output" | cut -f1))."
    exit 0
fi

TEMP_FILE="$(mktemp)"
TEMP_DIR="$(mktemp -d)"

for file in "$@"; do
    if [ ! -f "$file" ]; then
        error "File '$file' not found."
        rm -f "$TEMP_FILE"
        rm -rf "$TEMP_DIR"
        exit 1
    fi
    standardized_file="${TEMP_DIR}/standardized_$(basename "$file").wav"
    ffmpeg -y -i "$file" -ar 44100 -ac 2 -acodec pcm_s16le "$standardized_file"
    echo "file '$standardized_file'" >> "$TEMP_FILE"
done

full_filename_temp="${output_filename}.wav"
ffmpeg -y -f concat -safe 0 -i "$TEMP_FILE" -c copy "$full_filename_temp"
success "Audio files have been merged into '$full_filename_temp'."

rm -f "$TEMP_FILE"
rm -rf "$TEMP_DIR"

if [ "$output_format" != "wav" ]; then
    audiotox -f "$output_format" -i "$full_filename_temp"
    rm "$full_filename_temp"
fi
