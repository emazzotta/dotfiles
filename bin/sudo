#!/bin/bash

set -euo pipefail

if [[ "$(uname -s)" != "Darwin" ]]; then
    exec /usr/bin/sudo "$@"
fi

if /usr/bin/sudo -n true 2>/dev/null; then
    exec /usr/bin/sudo "$@"
fi

keyguard_available() {
    command -v envify &>/dev/null || return 1
    curl --connect-timeout 1 -s -o /dev/null "http://localhost:7777/" 2>/dev/null ||
        curl --connect-timeout 1 -s -o /dev/null "http://host.docker.internal:7777/" 2>/dev/null
}

if ! keyguard_available; then
    exec /usr/bin/sudo "$@"
fi

source envify MAC_SUDO_PW 2>/dev/null

pw_fifo=$(mktemp -u /tmp/.sudo_pw.XXXXXX)
askpass=$(mktemp /tmp/.sudo_askpass.XXXXXX)
trap 'rm -f "$pw_fifo" "$askpass"' EXIT

mkfifo -m 600 "$pw_fifo"
chmod 700 "$askpass"
printf '#!/bin/sh\ncat "%s"\n' "$pw_fifo" > "$askpass"

printf '%s\n' "$MAC_SUDO_PW" > "$pw_fifo" &

SUDO_ASKPASS="$askpass" /usr/bin/sudo -A "$@"
