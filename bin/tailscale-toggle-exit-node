#!/bin/bash

set -euo pipefail

source prettyprint

WORK_IP="46.245.188.32"

if ! command -v tailscale > /dev/null 2>&1; then
    printf "${YELLOW}●${RESET} Tailscale not installed\n"
    exit 0
fi

if ! command -v showip > /dev/null 2>&1; then
    printf "${YELLOW}●${RESET} showip not available, cannot determine exit node state\n"
    exit 0
fi

TS_JSON=$(tailscale status --json 2>/dev/null || true)
state=$(printf '%s' "$TS_JSON" | jq -r '.BackendState' 2>/dev/null || true)

if [ "$state" = "Running" ]; then
    EXIT_NODE_NAME=$(printf '%s' "$TS_JSON" | jq -r '[.Peer[] | select(.HostName | test("^ubuntu-devserver"))] | .[0].HostName // "ubuntu-devserver"' 2>/dev/null || echo "ubuntu-devserver")
    printf "${GREEN}●${RESET} Tailscale is connected\n"
else
    printf "${RED}●${RESET} Tailscale not connected\n"
    exit 0
fi

current_ip=$(showip -e 2>/dev/null || true)

if [ "$current_ip" = "$WORK_IP" ]; then
    printf "${GREEN}●${RESET} IP → %s\n" "$current_ip"
    printf "${YELLOW}●${RESET} Exit node active. Clear it? (y/N): "
    read -r answer
    if [ "${answer:-N}" = "y" ] || [ "${answer:-N}" = "Y" ]; then
        tailscale set --exit-node=
        printf "${YELLOW}●${RESET} Exit node cleared\n"
    else
        printf "${YELLOW}●${RESET} Exit node unchanged\n"
    fi
else
    printf "${WHITE}●${RESET} IP → %s\n" "$current_ip"
    printf "${YELLOW}●${RESET} No exit node active. Enable '%s'? (y/N): " "$EXIT_NODE_NAME"
    read -r answer
    if [ "${answer:-N}" = "y" ] || [ "${answer:-N}" = "Y" ]; then
        tailscale set --exit-node="$EXIT_NODE_NAME"
        printf "${GREEN}●${RESET} Exit node enabled: %s\n" "$EXIT_NODE_NAME"
    else
        printf "${YELLOW}●${RESET} Exit node unchanged\n"
    fi
fi
