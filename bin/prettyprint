#!/bin/bash
export GREEN='\033[32m'
export RED='\033[31m'
export YELLOW='\033[33m'
export WHITE='\033[37m'
export RESET='\033[0m'

info() {
    printf "${YELLOW}●${RESET} %s\n" "$*"
}

success() {
    printf "${GREEN}●${RESET} %s\n" "$*"
}

error() {
    printf "${RED}●${RESET} %s\n" "$*" >&2
}

substep_info() {
    printf "  ${YELLOW}·${RESET} %s\n" "$*"
}

substep_success() {
    printf "  ${GREEN}·${RESET} %s\n" "$*"
}

substep_error() {
    printf "  ${RED}·${RESET} %s\n" "$*" >&2
}
