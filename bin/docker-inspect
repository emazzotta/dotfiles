#!/bin/bash
set -euo pipefail

# shellcheck source=dockerlib.sh
source "$(dirname "${BASH_SOURCE[0]}")/dockerlib.sh"

show_usage() {
    cat << EOF
Usage: $(basename "$0") [container1 container2 ...]

Inspect running Docker containers and display their configuration.

If no container is specified:
  - Single running container: inspects it automatically
  - Multiple running containers: interactive selection via gum

Examples:
  $(basename "$0")
  $(basename "$0") nginx
  $(basename "$0") nginx postgres redis
EOF
}

inspect_container() {
    local container="$1"

    if ! docker inspect "$container" >/dev/null 2>&1; then
        echo "Error: container '$container' not found" >&2
        return 1
    fi

    docker inspect --format='Container: {{.Name}}
Image: {{.Config.Image}}
Ports: {{range $p, $conf := .NetworkSettings.Ports}}{{$p}}{{if $conf}}->{{(index $conf 0).HostPort}}{{end}} {{end}}
Env: {{range .Config.Env}}
  - {{.}}{{end}}
Volumes: {{range .Mounts}}
  - {{.Source}}:{{.Destination}}{{if .Mode}}:{{.Mode}}{{end}}{{end}}
Network: {{range $k,$v := .NetworkSettings.Networks}}{{$k}}{{end}}
---' "$container"
}

main() {
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
        show_usage
        exit 0
    fi

    dh_require_docker

    local containers=()

    if [ $# -eq 0 ]; then
        local selected
        if ! selected=$(dh_pick_container "Select containers to inspect:"); then
            exit 1
        fi
        while IFS= read -r name; do
            containers+=("$name")
        done <<< "$selected"
    else
        containers=("$@")
    fi

    if [ ${#containers[@]} -eq 0 ]; then
        echo "Error: no containers to inspect" >&2
        exit 1
    fi

    for container in "${containers[@]}"; do
        inspect_container "$container" || continue
    done
}

main "$@"
