#!/usr/bin/env python3

import argparse
import os
import shutil
import sys
import threading
from pathlib import Path
from subprocess import DEVNULL, PIPE, Popen, run
from time import perf_counter, time, time_ns

_PROFILE_ENABLED = os.environ.get("CL_PROFILE") == "1"
_profile_start = perf_counter()
_profile_last = _profile_start
_docker_events: list[tuple[float, str]] = []


def _profile(label: str) -> None:
    global _profile_last
    if not _PROFILE_ENABLED:
        return
    now = perf_counter()
    delta_ms = (now - _profile_last) * 1000
    total_ms = (now - _profile_start) * 1000
    print(f"[cl-profile] {label:36s} +{delta_ms:8.1f}ms  (total {total_ms:8.1f}ms)", file=sys.stderr)
    _profile_last = now


def _start_docker_events_monitor(container_name: str, baseline_ns: int) -> tuple[Popen, threading.Thread] | None:
    if not _PROFILE_ENABLED:
        return None
    docker_path = shutil.which("docker")
    if not docker_path:
        print("[cl-profile] docker events: docker not in PATH", file=sys.stderr)
        return None
    since_unix = str(baseline_ns // 1_000_000_000 - 1)
    cmd = [
        docker_path, "events",
        "--since", since_unix,
        "--filter", f"container={container_name}",
        "--format", "{{.TimeNano}}\t{{.Action}}",
    ]
    try:
        proc = Popen(cmd, stdout=PIPE, stderr=PIPE, text=True)
    except OSError as e:
        print(f"[cl-profile] docker events: spawn failed: {e}", file=sys.stderr)
        return None

    def reader() -> None:
        assert proc.stdout is not None
        for line in proc.stdout:
            line = line.strip()
            if not line or "\t" not in line:
                continue
            ts_str, status = line.split("\t", 1)
            try:
                ts_ns = int(ts_str)
            except ValueError:
                continue
            delta_ms = (ts_ns - baseline_ns) / 1_000_000
            _docker_events.append((delta_ms, status))

    thread = threading.Thread(target=reader, daemon=True)
    thread.start()
    return proc, thread


def _print_docker_events(monitor: tuple[Popen, threading.Thread] | None) -> None:
    if not _PROFILE_ENABLED:
        return
    if monitor is None:
        print("[cl-profile] docker events: monitor never started", file=sys.stderr)
        return
    proc, _thread = monitor
    exit_code = proc.poll()
    stderr_output = ""
    if proc.stderr is not None:
        try:
            stderr_output = (proc.stderr.read() or "").strip()
        except Exception as e:
            stderr_output = f"<read failed: {e}>"
    if not _docker_events:
        print(f"[cl-profile] docker events: NO events captured (exit={exit_code})", file=sys.stderr)
        if stderr_output:
            for line in stderr_output.splitlines():
                print(f"[cl-profile] docker events: stderr: {line}", file=sys.stderr)
        return
    for delta_ms, status in _docker_events:
        print(f"[cl-profile] docker event: {status:26s} +{delta_ms:8.1f}ms  (from docker run)", file=sys.stderr)
    if stderr_output:
        for line in stderr_output.splitlines():
            print(f"[cl-profile] docker events: stderr: {line}", file=sys.stderr)


OPENCODE_ROOT = Path.home() / "Projects" / "private" / "opencode"
COMPOSE_FILE = OPENCODE_ROOT / "docker-compose.yml"
LEONARDO_COMMONS = Path.home() / "Projects" / "leo-productions" / "leonardo-commons"
DOTFILES = Path.home() / "dotfiles"
DOTFILES_CONTAINER = "/home/opencode/dotfiles"
DOTFILES_CRUFT_PATTERNS = (
    "__pycache__", "*.pyc", "*.pyo",
    ".DS_Store",
    ".venv", "venv", "node_modules",
    ".pytest_cache", ".mypy_cache", ".ruff_cache", ".tox",
)


def _find_git_crypt_root(path: Path) -> Path | None:
    current = path
    while current != current.parent:
        if (current / ".git-crypt").is_dir():
            return current
        current = current.parent
    return None


def lock_git_crypt(pwd: Path, repo_root: Path | None = None) -> None:
    if not shutil.which("git-crypt"):
        return

    if repo_root is None:
        repo_root = _find_git_crypt_root(pwd)
    if repo_root is None:
        return

    stashed = _git_stash_push(repo_root)
    result = run(["git-crypt", "lock"], cwd=repo_root, capture_output=True, text=True)
    if result.returncode == 0:
        print(f"git-crypt: locked {repo_root.name}")
    elif "already locked" in result.stderr.lower():
        print(f"git-crypt: {repo_root.name} already locked")
    else:
        _git_stash_pop(repo_root, stashed)
        print(f"git-crypt: failed to lock {repo_root.name} - {result.stderr.strip()}", file=sys.stderr)
        sys.exit(1)
    _git_stash_pop(repo_root, stashed)


def _git_stash_push(pwd: Path) -> bool:
    result = run(["git", "stash", "push", "-u", "-m", "cl-auto-stash"], cwd=pwd, capture_output=True, text=True)
    return result.returncode == 0 and "no local changes" not in result.stdout.lower()


def _git_stash_pop(pwd: Path, stashed: bool) -> None:
    if not stashed:
        return
    result = run(["git", "stash", "pop"], cwd=pwd, capture_output=True, text=True)
    if result.returncode != 0:
        print(f"git stash pop failed: {result.stderr.strip()}", file=sys.stderr)


def parse_path(path_str: str) -> Path:
    path = Path(path_str).resolve()
    if not path.exists():
        raise argparse.ArgumentTypeError(f"Path does not exist: {path_str}")
    if not path.is_dir():
        raise argparse.ArgumentTypeError(f"Path is not a directory: {path_str}")
    return path


def validate_file_in_pwd(absolute_path: Path, pwd: Path, original_path: str) -> Path:
    try:
        return absolute_path.relative_to(pwd)
    except ValueError:
        print(f"Error: File must be within PWD: {original_path}", file=sys.stderr)
        sys.exit(1)


def is_home_dir(path: Path) -> bool:
    return path == Path.home()


def _container_path(path: Path, pwd: Path) -> str:
    try:
        rel = path.relative_to(pwd)
        return path.name if rel == Path(".") else str(rel)
    except ValueError:
        return path.name


def build_dotfiles_volume_args() -> list[str]:
    """Mount only git-tracked dotfiles content into the container.

    Walks ~/dotfiles and emits -v args for every tracked file and
    every directory whose contents are entirely tracked. Directories
    with a mix of tracked and sensitive gitignored files are drilled
    into so only the tracked children get mounted - sensitive files
    never appear in the container's namespace. .git is always mounted
    so the container can commit back to the host.

    Cruft (build artifacts, OS metadata - see DOTFILES_CRUFT_PATTERNS)
    does not force drilling. A directory with only cruft mixed in stays
    a whole-dir mount; the cruft comes along but is harmless.
    """
    if not (DOTFILES / ".git").is_dir():
        return []

    def git_lines(*args: str) -> set[str]:
        result = run(["git", "-C", str(DOTFILES), *args], capture_output=True, text=True)
        return set(result.stdout.splitlines()) if result.returncode == 0 else set()

    def is_cruft(path: str) -> bool:
        def matches(name: str, pattern: str) -> bool:
            if pattern.startswith("*."):
                return name.endswith(pattern[1:])
            return name == pattern
        return any(matches(part, pat) for part in path.split("/") for pat in DOTFILES_CRUFT_PATTERNS)

    tracked = git_lines("ls-files")
    _profile("  dotfiles: ls-files tracked")
    ignored = {f for f in git_lines("ls-files", "--others", "--ignored", "--exclude-standard", "--directory") if not is_cruft(f)}
    _profile("  dotfiles: ls-files ignored")

    def ancestors(paths: set[str]) -> set[str]:
        out: set[str] = set()
        for path in paths:
            parts = path.split("/")
            for i in range(1, len(parts)):
                out.add("/".join(parts[:i]))
        return out

    tracked_dirs = ancestors(tracked)
    dirty_dirs = ancestors(ignored)
    _profile("  dotfiles: ancestors sets")

    mounts: list[tuple[Path, str]] = [(DOTFILES / ".git", f"{DOTFILES_CONTAINER}/.git")]

    def walk(rel: str) -> None:
        host_dir = DOTFILES / rel if rel else DOTFILES
        for entry in sorted(host_dir.iterdir()):
            if entry.name == ".git":
                continue
            rel_entry = f"{rel}/{entry.name}" if rel else entry.name
            if entry.is_file():
                if rel_entry in tracked:
                    mounts.append((entry, f"{DOTFILES_CONTAINER}/{rel_entry}"))
            elif entry.is_dir():
                if rel_entry not in tracked_dirs:
                    continue
                if rel_entry in dirty_dirs:
                    walk(rel_entry)
                else:
                    mounts.append((entry, f"{DOTFILES_CONTAINER}/{rel_entry}"))

    walk("")
    _profile(f"  dotfiles: walk ({len(mounts)} mounts)")
    return [arg for host, container in mounts for arg in ("-v", f"{host}:{container}")]


def build_volume_args(files: list[str], paths: list[Path], pwd: Path) -> list[str]:
    if not files and not paths:
        if is_home_dir(pwd):
            print("Error: Refusing to mount home directory - run from a project directory", file=sys.stderr)
            sys.exit(1)
        return ["-v", f"{pwd}:/workspace/code/{pwd.name}"]

    volume_args: list[str] = []
    for path in paths:
        if is_home_dir(path):
            print(f"Skipping home directory mount: {path}", file=sys.stderr)
            continue
        volume_args.extend(["-v", f"{path}:/workspace/code/{_container_path(path, pwd)}"])
    for file_path in files:
        volume_args.extend(resolve_file_volume_args(file_path, pwd))
    return volume_args


def resolve_file_volume_args(file_path: str, pwd: Path) -> list[str]:
    if any(c in file_path for c in ("*", "?", "[")):
        return expand_glob_volume_args(file_path, pwd)
    return single_file_volume_args(file_path, pwd)


def expand_glob_volume_args(pattern: str, pwd: Path) -> list[str]:
    matches = [str(p.relative_to(pwd)) for p in pwd.glob(pattern)]
    if not matches:
        print(f"Error: No files matched pattern: {pattern}", file=sys.stderr)
        sys.exit(1)
    volume_args: list[str] = []
    for match in matches:
        volume_args.extend(single_file_volume_args(match, pwd))
    return volume_args


def single_file_volume_args(file_path: str, pwd: Path) -> list[str]:
    p = Path(file_path)
    absolute_path = p.resolve() if p.is_absolute() else (pwd / file_path).resolve()
    if not absolute_path.exists():
        print(f"Error: File not found: {file_path}", file=sys.stderr)
        sys.exit(1)
    relative_path = validate_file_in_pwd(absolute_path, pwd, file_path)
    return ["-v", f"{pwd / relative_path}:/workspace/code/{relative_path}"]


def main() -> None:
    pwd = Path.cwd()

    parser = argparse.ArgumentParser(prog="cl", usage="cl [-f FILE]... [-p PATH]... [-n] [-r [SEARCH]] [CLAUDE_ARGS...]")
    parser.add_argument("-f", "--file", dest="files", action="extend", nargs="+", default=[], metavar="FILE")
    parser.add_argument(
        "-p", "--path",
        dest="paths", action="append", type=parse_path, default=[], metavar="PATH",
        help="directory to mount; may be repeated: -p ~/a -p ~/b",
    )
    parser.add_argument("-n", "--no-skip", action="store_true", default=False)
    parser.add_argument("-o", "--oc", action="store_true", default=False, help="run opencode instead of claude")
    parser.add_argument(
        "-r", "--resume",
        nargs="?", const="", default=None, metavar="SEARCH",
        help="resume a session (opencode: interactive picker; claude: --resume)",
    )
    parser.add_argument("--convert", action="store_true", default=False, help="convert sessions between claude and opencode")

    args, claude_args = parser.parse_known_args()
    _profile("argparse")

    lock_targets = args.paths or [pwd]
    locked_roots: set[Path] = set()
    for directory in lock_targets:
        root = _find_git_crypt_root(directory)
        if root and root not in locked_roots:
            lock_git_crypt(directory, repo_root=root)
            locked_roots.add(root)
    _profile("git-crypt lock (targets)")

    if args.oc:
        sync_script = OPENCODE_ROOT / "opencode" / "workspace" / ".claude" / "scripts" / "sync-ollama-models"
        if sync_script.is_file():
            run([str(sync_script)], cwd=OPENCODE_ROOT)
        _profile("sync-ollama-models")

    volume_args = build_volume_args(args.files, args.paths, pwd)
    _profile("build_volume_args")
    dotfiles_volume_args = build_dotfiles_volume_args()
    _profile("build_dotfiles_volume_args")
    if LEONARDO_COMMONS.is_dir() and LEONARDO_COMMONS.resolve() not in locked_roots:
        lock_git_crypt(LEONARDO_COMMONS)
        mounted = any(str(LEONARDO_COMMONS) in v for v in volume_args)
        if not mounted:
            volume_args.extend(["-v", f"{LEONARDO_COMMONS}:/workspace/code/leonardo-commons"])
    _profile("leonardo-commons lock/mount")
    container_name = f"opencode-{int(time())}"
    skip_args = [] if args.no_skip else ["--dangerously-skip-permissions"]

    if args.convert:
        entrypoint = "session-convert"
        entrypoint_args = claude_args
    elif args.oc:
        if args.resume is not None:
            entrypoint = "opencode-resume"
            resume_args = [args.resume] if args.resume else []
            entrypoint_args = [*resume_args, *claude_args]
        else:
            entrypoint = "opencode"
            entrypoint_args = claude_args
    else:
        resume_args = []
        if args.resume is not None:
            resume_args = ["--resume", args.resume] if args.resume else ["--resume"]
        entrypoint = "claude"
        entrypoint_args = [*skip_args, *resume_args, *claude_args]

    plugin_args = []
    if entrypoint == "claude":
        plugin_dir = Path("/workspace/.claude/plugins")
        plugin_args = [
            arg
            for d in sorted(plugin_dir.iterdir()) if d.is_dir()
            for arg in ("--plugin-dir", str(d))
        ] if plugin_dir.is_dir() else []

    _profile("plugin dir scan")
    command = [
        "docker", "compose",
        "-f", str(COMPOSE_FILE),
        "-p", "opencode",
        "run", "--remove-orphans", "--rm",
        "--name", container_name,
        *dotfiles_volume_args,
        *volume_args,
        "opencode",
        entrypoint,
        *plugin_args,
        *entrypoint_args,
    ]
    _profile("handoff to docker compose")

    monitor = _start_docker_events_monitor(container_name, time_ns())
    try:
        result = run(command)
    finally:
        if monitor is not None:
            events_proc, events_thread = monitor
            events_proc.terminate()
            events_thread.join(timeout=1.0)
        _print_docker_events(monitor)
    sys.exit(result.returncode)


if __name__ == "__main__":
    main()
