#!/bin/bash

GLOBAL_ENV_FILE="$HOME/dotfiles/.env"

load_global_env() {
    [ ! -f "$GLOBAL_ENV_FILE" ] && return 0
    set -a
    # shellcheck source=/dev/null
    . "$GLOBAL_ENV_FILE"
    set +a
}

resolve_params() {
    for key in "$@"; do
        if ! printenv "$key" > /dev/null 2>&1; then
            value=$(keyguard get "$key") || { echo "Error: failed to resolve '$key'" >&2; return 1; }
            export "$key=$value"
        fi
    done
}

load_global_env

if [ $# -gt 0 ]; then
    resolve_params "$@"
fi
