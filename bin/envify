#!/bin/bash
# Do NOT add `set -euo pipefail` — this script is meant to be sourced into
# interactive shells. Strict mode would leak into the caller's session and
# cause unrelated commands to abort the terminal.

GLOBAL_ENV_FILE="$HOME/dotfiles/.env"
PARAM_SERVER_PORT=7777
CACHE_QS="?timeout=${ENVIFY_CACHE_TIMEOUT:-120}"

load_global_env() {
    if [ ! -f "$GLOBAL_ENV_FILE" ]; then
        return 0
    fi
    set -a
    # shellcheck source=/dev/null
    . "$GLOBAL_ENV_FILE"
    set +a
}

find_reachable_param_host() {
    for host in localhost host.docker.internal; do
        if curl --connect-timeout 2 -s -o /dev/null "http://$host:$PARAM_SERVER_PORT/" 2>/dev/null; then
            echo "$host"
            return 0
        fi
    done
    return 1
}

fetch_params_from_server() {
    local host
    if ! host=$(find_reachable_param_host); then
        echo "Error: param server unreachable on localhost:$PARAM_SERVER_PORT and host.docker.internal:$PARAM_SERVER_PORT" >&2
        return 1
    fi
    local source_header="X-Keyguard-Source: $(hostname)"
    if [ $# -eq 1 ]; then
        printf '%s=%s\n' "$1" "$(curl -sf -H "$source_header" "http://$host:$PARAM_SERVER_PORT/$1$CACHE_QS")"
    else
        local IFS=','
        curl -sf -H "$source_header" "http://$host:$PARAM_SERVER_PORT/$*$CACHE_QS"
    fi
}

resolve_all_params() {
    if command -v keyguard > /dev/null 2>&1; then
        if [ $# -eq 1 ]; then
            printf '%s=%s\n' "$1" "$(keyguard get "$1")"
        else
            keyguard get "$@"
        fi
    else
        fetch_params_from_server "$@"
    fi
}

list_available_params() {
    if command -v keyguard > /dev/null 2>&1; then
        keyguard list
    else
        local host
        if ! host=$(find_reachable_param_host); then
            echo "Error: param server unreachable on localhost:$PARAM_SERVER_PORT and host.docker.internal:$PARAM_SERVER_PORT" >&2
            return 1
        fi
        curl -sf "http://$host:$PARAM_SERVER_PORT/_keys$CACHE_QS"
    fi
}

bridge_resolve_token() {
    if command -v keyguard > /dev/null 2>&1; then
        keyguard get MAC_BRIDGE_TOKEN
    else
        local host
        if ! host=$(find_reachable_param_host); then
            echo "Error: bridge: param server unreachable on localhost:$PARAM_SERVER_PORT and host.docker.internal:$PARAM_SERVER_PORT" >&2
            return 1
        fi
        curl -sf "http://$host:$PARAM_SERVER_PORT/MAC_BRIDGE_TOKEN"
    fi
}

list_bridge_endpoints() {
    local token host
    token=$(bridge_resolve_token) || return 1
    if ! host=$(find_reachable_param_host); then
        echo "Error: bridge: param server unreachable on localhost:$PARAM_SERVER_PORT and host.docker.internal:$PARAM_SERVER_PORT" >&2
        return 1
    fi
    curl -sf "http://$host:$PARAM_SERVER_PORT/_bridge/list" \
        -H "Authorization: Bearer $token"
}

call_bridge_endpoint() {
    local name="$1"
    local token host
    token=$(bridge_resolve_token) || return 1
    if ! host=$(find_reachable_param_host); then
        echo "Error: bridge: param server unreachable on localhost:$PARAM_SERVER_PORT and host.docker.internal:$PARAM_SERVER_PORT" >&2
        return 1
    fi
    curl -sf -X POST "http://$host:$PARAM_SERVER_PORT/_bridge/$name" \
        -H "Authorization: Bearer $token"
}

export_resolved_params() {
    local line key value
    while IFS= read -r line; do
        key="${line%%=*}"
        value="${line#*=}"
        if [ -n "$key" ]; then
            if [[ "$value" == base64:* ]]; then
                value=$(base64 -d <<< "${value#base64:}" 2>/dev/null) || value="${value}"
            fi
            export "$key=$value"
        fi
    done <<< "$1"
}

resolve_params() {
    local key
    local unresolved=()
    for key in "$@"; do
        if ! printenv "$key" > /dev/null 2>&1; then
            unresolved+=("$key")
        fi
    done

    if [ ${#unresolved[@]} -eq 0 ]; then
        return 0
    fi

    local output
    output=$(resolve_all_params "${unresolved[@]}") || {
        echo "Error: failed to resolve params: ${unresolved[*]}" >&2
        return 1
    }
    export_resolved_params "$output"
}

load_global_env

if [ $# -gt 0 ]; then
    if [ "$1" = "--list" ]; then
        list_available_params
    elif [ "$1" = "--bridge-list" ]; then
        list_bridge_endpoints
    elif [ "$1" = "--bridge" ]; then
        if [ $# -lt 2 ]; then
            echo "Usage: envify --bridge <endpoint-name>" >&2
            return 1
        fi
        call_bridge_endpoint "$2"
    else
        resolve_params "$@"
    fi
fi
