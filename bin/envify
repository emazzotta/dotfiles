#!/bin/bash
# Do NOT add set -euo pipefail - this script is sourced into interactive shells.

_ENVIFY_PY="${DOTFILESPATH:-$HOME/dotfiles}/bin/envify.py"

if [ $# -eq 0 ]; then
    return 0 2>/dev/null || exit 0
fi

case "${1:-}" in
    -*)
        # Flags: --help, --list, --bridge-list, --bridge - output directly
        python3 "$_ENVIFY_PY" "$@"
        ;;
    *)
        # Var names: eval the export statements into the current shell
        eval "$(python3 "$_ENVIFY_PY" "$@")"
        ;;
esac
