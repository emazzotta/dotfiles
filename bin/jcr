#!/bin/bash
# jcr - thin launcher for the jira-workflow Claude Code plugin's CLI.
# Finds the installed plugin's jcr (from any marketplace) and runs it, loading Jira credentials
# from keyguard if the vars the CLI expects are not already in the environment.
# The tool's logic lives in the plugin; this just puts `jcr` on PATH outside a plugin-aware shell.
set -uo pipefail

# shellcheck disable=SC2012
plugin_jcr="$(ls -d "$HOME"/.claude/plugins/cache/*/jira-workflow/*/bin/jcr 2>/dev/null | sort -V | tail -1)"
if [ -z "$plugin_jcr" ] || [ ! -x "$plugin_jcr" ]; then
  echo "jcr: the jira-workflow plugin is not installed (claude plugin install jira-workflow@<marketplace>)" >&2
  exit 1
fi

if [ -z "${ATLASSIAN_TOKEN:-}" ] && command -v envify-as >/dev/null 2>&1; then
  eval "$(envify-as ATLASSIAN_EMAIL=JIRA_EMAIL ATLASSIAN_TOKEN=JIRA_TOKEN)"
fi

exec "$plugin_jcr" "$@"
