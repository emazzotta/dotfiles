#!/bin/bash
set -euo pipefail

JIRA_URL="https://leonardo-productions.atlassian.net"
JIRA_EMAIL="emanuele.mazzotta@leonardo.ag"
DEFAULT_PROJECT="LEO"
DEFAULT_TYPE="Task"
DEFAULT_FIX_VERSION="25.3.0"
SPRINT_FIELD="customfield_10020"
BOARD_ID="11"
ACCOUNT_ID="712020:ee7ed959-0679-4e8c-aa1c-ed33c9327198"
DEFAULT_STATUS="READY FOR DEV"

error() {
    gum style --foreground 196 "Error: $*" >&2
    exit 1
}

warn() {
    gum style --foreground 214 "Warning: $*" >&2
}

check_deps() {
    local missing=()
    for cmd in gum curl jq; do
        command -v "$cmd" &>/dev/null || missing+=("$cmd")
    done
    if [ ${#missing[@]} -gt 0 ]; then
        echo "Missing required tools: ${missing[*]}" >&2
        echo "" >&2
        for cmd in "${missing[@]}"; do
            case "$cmd" in
                gum)  echo "  brew install gum" >&2 ;;
                curl) echo "  brew install curl" >&2 ;;
                jq)   echo "  brew install jq" >&2 ;;
            esac
        done
        exit 1
    fi
    if [ -z "${JIRA_TOKEN:-}" ]; then
        echo "JIRA_TOKEN environment variable is not set." >&2
        echo "Add to your shell profile: export JIRA_TOKEN=\"your-api-token\"" >&2
        echo "Get a token at: https://id.atlassian.com/manage-profile/security/api-tokens" >&2
        exit 1
    fi
}

jira_get() {
    local path="$1"
    local response
    response=$(curl -sf \
        -u "${JIRA_EMAIL}:${JIRA_TOKEN}" \
        -H "Accept: application/json" \
        "${JIRA_URL}/rest/${path}") || error "API request failed: GET ${path}"
    echo "$response"
}

fetch_board_id() {
    local result board_id
    result=$(jira_get "agile/1.0/board?projectKeyOrId=${DEFAULT_PROJECT}&type=scrum")
    board_id=$(echo "$result" | jq -r '.values[0].id // empty')
    [ -n "$board_id" ] || error "No scrum board found for project ${DEFAULT_PROJECT}"
    echo "$board_id"
}

fetch_versions() {
    local versions
    versions=$(jira_get "api/3/project/${DEFAULT_PROJECT}/versions" \
        | jq -r '[.[] | select(.released==false)] | reverse | .[].name')
    [ -n "$versions" ] || error "No unreleased versions found for project ${DEFAULT_PROJECT}"
    echo "$versions"
}

fetch_sprints() {
    local board_id="$1"
    local active future
    active=$(jira_get "agile/1.0/board/${board_id}/sprint?state=active" | jq -r '.values[].name' 2>/dev/null || true)
    future=$(jira_get "agile/1.0/board/${board_id}/sprint?state=future" | jq -r '.values[].name' 2>/dev/null || true)
    [ -n "$active" ] || [ -n "$future" ] || error "No active or future sprints found for board ${board_id}"
    if [ -n "$active" ]; then printf '%s\n' "$active"; fi
    if [ -n "$future" ]; then printf '%s\n' "$future"; fi
}

fetch_sprint_id() {
    local board_id="$1" sprint_name="$2"
    local result sprint_id
    result=$(jira_get "agile/1.0/board/${board_id}/sprint?state=active&maxResults=50")
    sprint_id=$(echo "$result" | jq -r --arg name "$sprint_name" '.values[] | select(.name==$name) | .id // empty')
    if [ -z "$sprint_id" ]; then
        result=$(jira_get "agile/1.0/board/${board_id}/sprint?state=future&maxResults=50")
        sprint_id=$(echo "$result" | jq -r --arg name "$sprint_name" '.values[] | select(.name==$name) | .id // empty')
    fi
    [ -n "$sprint_id" ] || error "Could not find sprint ID for: ${sprint_name}"
    echo "$sprint_id"
}

fetch_account_id() {
    local id
    id=$(jira_get "api/3/myself" | jq -r '.accountId // empty')
    [ -n "$id" ] || error "Could not fetch your Jira account ID"
    echo "$id"
}

transition_issue() {
    local key="$1" status_name="$2"
    local transitions transition_id
    transitions=$(jira_get "api/3/issue/${key}/transitions")
    transition_id=$(echo "$transitions" | jq -r --arg name "$status_name" \
        '.transitions[] | select(.name | ascii_downcase == ($name | ascii_downcase)) | .id // empty' | head -1)
    if [ -z "$transition_id" ]; then
        warn "Transition '${status_name}' not found — ticket left in default status"
        return
    fi
    curl -s -u "${JIRA_EMAIL}:${JIRA_TOKEN}" \
        -H "Content-Type: application/json" \
        -X POST \
        -d "{\"transition\":{\"id\":\"${transition_id}\"}}" \
        "${JIRA_URL}/rest/api/3/issue/${key}/transitions" > /dev/null
}

build_payload() {
    local summary="$1" description="$2" fix_version="$3" issue_type="$4" sprint_id="$5" sprint_field="$6" account_id="$7"

    local base
    base=$(jq -n \
        --arg project "$DEFAULT_PROJECT" \
        --arg summary "$summary" \
        --arg fix_version "$fix_version" \
        --arg issue_type "$issue_type" \
        --arg account_id "$account_id" \
        '{fields: {project: {key: $project}, summary: $summary, issuetype: {name: $issue_type}, fixVersions: [{name: $fix_version}], assignee: {accountId: $account_id}}}')

    if [ -n "$description" ]; then
        # ADF (Atlassian Document Format) required for Jira Cloud description field
        base=$(echo "$base" | jq \
            --argjson desc \
            "{\"type\":\"doc\",\"version\":1,\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":$(echo "$description" | jq -Rs '.')}]}]}" \
            '.fields.description = $desc')
    fi

    if [ -n "$sprint_field" ] && [ -n "$sprint_id" ]; then
        base=$(echo "$base" | jq --arg sf "$sprint_field" --argjson sid "$sprint_id" '.fields[$sf] = $sid')
    fi

    echo "$base"
}

run_setup() {
    echo ""
    gum style --bold "jcr setup — discovering Jira configuration"
    echo ""

    local board_id
    board_id=$(gum spin --title "Fetching board for ${DEFAULT_PROJECT}..." --show-output -- \
        bash -c "curl -sf \
            -u '${JIRA_EMAIL}:${JIRA_TOKEN}' \
            -H 'Accept: application/json' \
            '${JIRA_URL}/rest/agile/1.0/board?projectKeyOrId=${DEFAULT_PROJECT}&type=scrum' \
        | jq -r '.values[0].id // empty'") || error "Failed to fetch board"
    [ -n "$board_id" ] || error "No scrum board found for project ${DEFAULT_PROJECT}"

    echo "Fetching a recent ticket to identify the sprint field..."
    local search_response
    search_response=$(curl -s \
        -u "${JIRA_EMAIL}:${JIRA_TOKEN}" \
        -H "Accept: application/json" \
        "${JIRA_URL}/rest/api/3/search/jql?jql=project%3D${DEFAULT_PROJECT}%20ORDER%20BY%20created%20DESC&maxResults=1&fields=*all")

    local api_error
    api_error=$(echo "$search_response" | jq -r '.errorMessages[0] // empty' 2>/dev/null)
    [ -z "$api_error" ] || error "Jira API error: ${api_error}"

    local raw_fields
    raw_fields=$(echo "$search_response" | jq -r '
        .issues[0].fields | to_entries[]
        | select(.key | startswith("customfield_"))
        | select(.value != null)
        | select(.value | type == "array")
        | select(length > 0)
        | select(.value[0] | objects | (has("id") and has("name") and has("state")))
        | "\(.key)  →  \(.value[0].name)"' 2>/dev/null)

    if [ -z "$raw_fields" ]; then
        error "Could not find sprint-like fields on the most recent ${DEFAULT_PROJECT} ticket. Make sure the ticket has a sprint assigned."
    fi

    echo ""
    local sprint_field_line
    sprint_field_line=$(echo "$raw_fields" | gum choose --header "Which field is the Sprint? (select the one showing the sprint name)")
    local sprint_field
    sprint_field=$(echo "$sprint_field_line" | awk '{print $1}')

    local account_id
    account_id=$(jira_get "api/3/myself" | jq -r '.accountId // empty')

    echo ""
    gum style --foreground 82 "Update these constants in the jcr script:"
    echo "  BOARD_ID=\"${board_id}\""
    echo "  SPRINT_FIELD=\"${sprint_field}\""
    echo "  ACCOUNT_ID=\"${account_id}\""
    echo ""
}

show_help() {
    cat << 'EOF'
jcr — Jira CReate: interactive Jira ticket creation

Usage:
  jcr              Create a new Jira ticket interactively
  jcr --setup      Discover BOARD_ID and SPRINT_FIELD values
  jcr --dry-run    Show JSON payload without creating ticket
  jcr --help       Show this help

Requires: export JIRA_TOKEN="your-api-token" in your shell profile
EOF
}

main() {
    local dry_run=false do_setup=false

    for arg in "$@"; do
        case "$arg" in
            --dry-run|-n) dry_run=true ;;
            --setup)      do_setup=true ;;
            --help|-h)    show_help; exit 0 ;;
            *) echo "Unknown argument: $arg" >&2; show_help; exit 2 ;;
        esac
    done

    check_deps

    if [ "$do_setup" = "true" ]; then
        run_setup
        return
    fi

    if [[ "$SPRINT_FIELD" != customfield_* ]]; then
        echo "SPRINT_FIELD=\"${SPRINT_FIELD}\" looks wrong — expected customfield_XXXXX format." >&2
        echo "Run: jcr --setup" >&2
        exit 1
    fi

    local board_id="${BOARD_ID:-}"
    [ -n "$board_id" ] || board_id=$(fetch_board_id)

    local summary
    summary=$(gum input --placeholder "Ticket summary" --prompt "> ")
    [ -n "$summary" ] || error "Summary is required"

    local description=""
    if gum confirm "Add description?"; then
        description=$(gum write --placeholder "Description...")
    fi

    local versions_list ordered_versions
    versions_list=$(fetch_versions)
    if echo "$versions_list" | grep -qx "$DEFAULT_FIX_VERSION"; then
        ordered_versions="$DEFAULT_FIX_VERSION"$'\n'$(echo "$versions_list" | grep -vx "$DEFAULT_FIX_VERSION")
    else
        ordered_versions="$versions_list"
    fi
    local fix_version
    fix_version=$(echo "$ordered_versions" | gum choose --header "Fix Version")

    local sprint
    sprint=$(fetch_sprints "$board_id" | gum choose --header "Sprint")

    local type_options
    type_options="$DEFAULT_TYPE"$'\n'$(printf 'Story\nBug\nEpic\nSub-task' | grep -vx "$DEFAULT_TYPE")
    local issue_type
    issue_type=$(echo "$type_options" | gum choose --header "Issue Type")

    gum confirm "Create ${issue_type} in ${DEFAULT_PROJECT}?" || { echo "Aborted."; exit 0; }

    local sprint_id=""
    if [ -n "$SPRINT_FIELD" ] && [ -n "$sprint" ]; then
        sprint_id=$(fetch_sprint_id "$board_id" "$sprint")
    fi

    local account_id="${ACCOUNT_ID:-}"
    [ -n "$account_id" ] || account_id=$(fetch_account_id)

    local payload
    payload=$(build_payload "$summary" "$description" "$fix_version" "$issue_type" "$sprint_id" "$SPRINT_FIELD" "$account_id")

    if [ "$dry_run" = "true" ]; then
        echo "$payload" | jq .
        return
    fi

    local tmp_payload tmp_result
    tmp_payload=$(mktemp)
    tmp_result=$(mktemp)
    echo "$payload" > "$tmp_payload"

    gum spin --title "Creating ticket..." -- \
        curl -s \
        -u "${JIRA_EMAIL}:${JIRA_TOKEN}" \
        -H "Accept: application/json" \
        -H "Content-Type: application/json" \
        -X POST \
        --data "@${tmp_payload}" \
        -o "$tmp_result" \
        "${JIRA_URL}/rest/api/3/issue"
    rm -f "$tmp_payload"

    local result key
    result=$(cat "$tmp_result")
    rm -f "$tmp_result"

    key=$(echo "$result" | jq -r '.key // empty')
    if [ -z "$key" ]; then
        local errmsg
        errmsg=$(echo "$result" | jq -r '(.errorMessages // []) + ([.errors // {} | to_entries[] | .value]) | join(", ")' 2>/dev/null || echo "$result")
        error "Failed to create ticket: ${errmsg}"
    fi

    transition_issue "$key" "$DEFAULT_STATUS"

    echo ""
    gum style --foreground 82 "${key} → ${JIRA_URL}/browse/${key}"
}

main "$@"
