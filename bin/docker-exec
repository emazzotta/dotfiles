#!/bin/bash
set -euo pipefail

# shellcheck source=dockerlib.sh
source "${BASH_SOURCE[0]%/*}/dockerlib.sh"

show_usage() {
    cat << EOF
Usage: $(basename "$0") [-s SERVER] [-c CONTAINER] [COMMAND...]

Execute a command in a running Docker container.

If no command is given, tries /bin/bash then falls back to /bin/sh.
If no container is specified:
  - Single running container: selects it automatically
  - Multiple running containers: interactive selection via gum

With -s/--server, the docker daemon on that host (resolved via ssh) is
used. The server name must resolve through ~/.ssh/config or DNS.

Examples:
  $(basename "$0")
  $(basename "$0") -c nginx
  $(basename "$0") -c nginx ls -la
  $(basename "$0") -s dev
  $(basename "$0") -s dev -c nginx ls -la
  $(basename "$0") python3 -c 'print("hi")'
EOF
}

detect_shell() {
    local container="$1"
    if docker exec "$container" test -x /bin/bash 2>/dev/null; then
        echo "/bin/bash"
    else
        echo "/bin/sh"
    fi
}

main() {
    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
        show_usage
        exit 0
    fi

    local container=""
    local server=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -c)
                if [ -z "${2:-}" ]; then
                    echo "Error: -c requires a container name" >&2
                    exit 1
                fi
                container="$2"
                shift 2
                ;;
            -s|--server)
                if [ -z "${2:-}" ]; then
                    echo "Error: $1 requires a server name" >&2
                    exit 1
                fi
                server="$2"
                shift 2
                ;;
            *)
                break
                ;;
        esac
    done

    [ -n "$server" ] && dh_use_remote_server "$server"

    dh_require_docker

    local cmd=("$@")

    if [ -z "$container" ]; then
        container=$(dh_pick_container) || exit 1
    fi

    dh_assert_container_exists "$container"

    if [ ${#cmd[@]} -eq 0 ]; then
        local shell
        shell=$(detect_shell "$container")
        cmd=("$shell")
    fi

    exec docker exec -it "$container" "${cmd[@]}"
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
