#!/bin/bash
set -euo pipefail

source prettyprint

AD_ACCOUNT_KEYCHAIN_NAME="LeonardoActiveDirectoryUsername"

ad_account=$(security find-generic-password \
    -a "$AD_ACCOUNT_KEYCHAIN_NAME" \
    -s "$AD_ACCOUNT_KEYCHAIN_NAME" \
    -w 2>/dev/null) || {
    printf "${RED}●${RESET} AD account not yet stored in keychain - run leonardo_drive or leonardo_vpn_toggle first to set it up\n" >&2
    exit 1
}

ad_password_name="LeonardoActiveDirectory:$ad_account"

read -s -r -p "Enter new AD password for $ad_account: " new_password
echo

if [ -z "$new_password" ]; then
    printf "${RED}●${RESET} No password provided - aborting\n" >&2
    exit 1
fi

security delete-generic-password -a "$ad_account" -s "$ad_password_name" >/dev/null 2>&1 || true
security add-generic-password -a "$ad_account" -s "$ad_password_name" -w "$new_password"
unset new_password

printf "${GREEN}●${RESET} AD password updated in keychain for $ad_account\n"
