#!/bin/bash
set -euo pipefail

root_dir="$(pwd)"
[ -n "${1:-}" ] && root_dir="${1}"

[ -f "${CUSTOM_BIN_DIR}/prettyprint" ] && source "${CUSTOM_BIN_DIR}/prettyprint"

CUSTOM_RELEASE_PATTERN="^[0-9]+.([0-9]+|x)(.[0-9]+|.x)?$"

output_file=$(mktemp)
status_file=$(mktemp)
trap 'rm -f "${output_file}" "${status_file}"' EXIT

separator() {
    printf "${BOLD}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}\n"
}

convert_git_url_to_http() {
    local git_url="$1"
    [[ "$git_url" =~ ^git@ ]] && git_url=$(echo "$git_url" | sed -E 's#git@([^:]+):#https://\1/#')
    echo "${git_url%.git}"
}

has_remote_access() {
    local remote_url="$1"
    curl -k --silent --head --connect-timeout 5 "$remote_url" &> /dev/null || return 1
}

has_git_access() {
    local remote_url
    remote_url=$(git -C "$1" remote get-url origin 2>/dev/null) || return 1
    has_remote_access "$(convert_git_url_to_http "$remote_url")" || return 1
}

pull_branch() {
    local branch="$1"
    local dir="$2"
    [ -n "${dir}" ] || return 1
    if git -C "${dir}" rev-parse --verify "origin/${branch}" &> /dev/null && git -C "${dir}" checkout "${branch}" &> /dev/null; then
        if ! git -C "${dir}" pull --quiet --rebase 2>/dev/null; then
            { separator; printf "${BOLD}${WHITE}%s${RESET} [pull failed: %s]\n" "${dir}" "${branch}"; } >> "${output_file}"
        fi
        git -C "${dir}" checkout --quiet -
    fi
}

pull_branches_by_regex() {
    local pattern="$1"
    local dir="$2"
    [ -n "${dir}" ] || return 1
    git -C "${dir}" branch -r | sed 's/origin\///g' | sed 's/ //g' | grep -E "${pattern}" | while read -r branch; do
        pull_branch "${branch}" "${dir}"
    done
}

update_repos() {
    find "${root_dir}" -mindepth 0 -maxdepth 3 -type d -or -type l | while read -r dir; do
        if [ -d "${dir}/.git" ]; then
            printf '%s' "${dir}" > "${status_file}"
            if has_git_access "${dir}"; then
                pull_branch "main" "${dir}"
                pull_branch "master" "${dir}"
                pull_branches_by_regex "${CUSTOM_RELEASE_PATTERN}" "${dir}"
                local branch_name
                branch_name=$(git -C "${dir}" rev-parse --abbrev-ref HEAD)
                if [ "${branch_name}" != "master" ] && [ "${branch_name}" != "main" ]; then
                    if ! git -C "${dir}" pull --quiet --rebase 2>/dev/null; then
                        { separator; printf "${BOLD}${WHITE}%s${RESET} [pull failed: %s]\n" "${dir}" "${branch_name}"; } >> "${output_file}"
                    fi
                fi
            else
                { separator; printf "${BOLD}${WHITE}%s${RESET} [no remote access]\n" "${dir}"; } >> "${output_file}"
            fi
        fi
    done
}

spin() {
    local spinners='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    local i=0
    while kill -0 "${UPDATE_PID}" 2>/dev/null; do
        local current
        current=$(cat "${status_file}" 2>/dev/null || echo "")
        printf "\033[2K\r  ${YELLOW}%s${RESET}  %s" "${spinners:$((i % 10)):1}" "${current}" >&2
        sleep 0.1
        i=$((i + 1))
    done
    printf "\r%-100s\r" "" >&2
}

update_repos &
UPDATE_PID=$!
spin
wait "${UPDATE_PID}"

cat "${output_file}"
[ -s "${output_file}" ] && separator

success "Done."
