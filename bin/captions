#!/usr/bin/env python3
"""Burn Hormozi-style karaoke captions into a short-form video, fully local.

Pipeline: extract audio -> faster-whisper word timestamps -> styled .ass
(one word highlighted at a time) -> ffmpeg burn-in. No cloud, no upload.
"""
from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import subprocess
import sys
import time
import urllib.request
from dataclasses import dataclass
from pathlib import Path
from typing import Final

FONT_URL: Final = "https://github.com/google/fonts/raw/main/ofl/anton/Anton-Regular.ttf"
FONT_NAME: Final = "Anton"
CACHE: Final = Path.home() / ".cache" / "captions"
VENV: Final = CACHE / "venv"
TRANSCRIPTS: Final = CACHE / "transcripts"
SENTENCE_END: Final = re.compile(r"[.!?]$")
STRIP_TRAILING: Final = re.compile(r"[.,;:]+$")
BOOTSTRAP_FLAG: Final = "CAPTIONS_BOOTSTRAPPED"
LAST_WORD_TAIL: Final = 0.15
HEX_COLOUR: Final = re.compile(r"^#?[0-9A-Fa-f]{6}$")
DEFAULT_PALETTE: Final = (
    "#22FF00",  # green
    "#3B82FF",  # blue
    "#A24BFF",  # violet
    "#FF2E9A",  # pink
    "#FF3B30",  # red
    "#FFC400",  # amber
)


@dataclass(frozen=True)
class Word:
    text: str
    start: float
    end: float

    @property
    def display(self) -> str:
        return STRIP_TRAILING.sub("", self.text).upper()

    @property
    def ends_sentence(self) -> bool:
        return SENTENCE_END.search(self.text) is not None


@dataclass(frozen=True)
class Style:
    font_size: int
    outline: int
    highlights: tuple[str, ...]
    max_words: int
    max_gap: float
    play_w: int
    play_h: int
    margin_v: int
    alignment: int


def run(cmd: list[str]) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(cmd, check=True, capture_output=True, text=True)
    except subprocess.CalledProcessError as exc:
        detail = (exc.stderr or exc.stdout or "").strip()
        raise SystemExit(f"{cmd[0]} failed (exit {exc.returncode}): {detail}")


def log(message: str) -> None:
    print(f"[{time.strftime('%H:%M:%S')}] {message}", file=sys.stderr, flush=True)


def _transcript_key(video: Path, model_name: str, language: str | None) -> Path:
    stat = video.stat()
    seed = f"{video.resolve()}|{stat.st_size}|{stat.st_mtime_ns}|{model_name}|{language or 'auto'}"
    digest = hashlib.sha256(seed.encode()).hexdigest()[:16]
    return TRANSCRIPTS / f"{digest}.json"


def _load_transcript(path: Path) -> list[Word] | None:
    if not path.exists():
        return None
    try:
        entries = json.loads(path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return None
    return [Word(text=e["text"], start=e["start"], end=e["end"]) for e in entries]


def _save_transcript(path: Path, words: list[Word]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    entries = [{"text": w.text, "start": w.start, "end": w.end} for w in words]
    path.write_text(json.dumps(entries), encoding="utf-8")


def provision_python() -> str:
    """Create a cached uv venv with faster-whisper and return its interpreter."""
    log("Setting up local transcription runtime (one-time)...")
    VENV.parent.mkdir(parents=True, exist_ok=True)
    create = ["uv", "venv", str(VENV)]
    if VENV.exists():
        create.insert(2, "--clear")
    run(create)
    env = {**os.environ, "UV_HTTP_TIMEOUT": "120", "VIRTUAL_ENV": str(VENV)}
    subprocess.run(
        ["uv", "pip", "install", "-q", "faster-whisper"],
        check=True, env=env, text=True,
    )
    return str(VENV / "bin" / "python")


def ensure_runtime() -> None:
    """Re-exec under a venv that has faster-whisper if the import is missing."""
    try:
        import faster_whisper  # noqa: F401
        return
    except ImportError:
        pass
    if os.environ.get(BOOTSTRAP_FLAG):
        sys.exit(
            f"faster-whisper unavailable even after bootstrap; remove {VENV} and retry"
        )
    venv_python = VENV / "bin" / "python"
    python = str(venv_python) if venv_python.exists() else provision_python()
    os.execve(
        python, [python, str(Path(__file__).resolve()), *sys.argv[1:]],
        {**os.environ, BOOTSTRAP_FLAG: "1"},
    )


def ensure_subtitles_filter() -> None:
    """Fail fast when ffmpeg was built without libass (no subtitles filter)."""
    filters = run(["ffmpeg", "-hide_banner", "-filters"]).stdout
    available = any(
        len(fields) >= 2 and fields[1] == "subtitles"
        for fields in (line.split() for line in filters.splitlines())
    )
    if not available:
        sys.exit(
            "ffmpeg has no 'subtitles' filter (built without libass). "
            "Homebrew's core ffmpeg no longer ships it; install a full build:\n"
            "  brew uninstall ffmpeg\n"
            "  brew tap homebrew-ffmpeg/ffmpeg\n"
            "  brew install homebrew-ffmpeg/ffmpeg/ffmpeg"
        )


def probe_dimensions(video: Path) -> tuple[int, int]:
    out = run([
        "ffprobe", "-v", "error", "-select_streams", "v:0",
        "-show_entries", "stream=width,height",
        "-of", "csv=s=x:p=0", str(video),
    ]).stdout.strip()
    width, height = out.split("x")
    return int(width), int(height)


def extract_audio(video: Path, work: Path) -> Path:
    wav = work / "audio.wav"
    run([
        "ffmpeg", "-y", "-loglevel", "error", "-i", str(video),
        "-ar", "16000", "-ac", "1", str(wav),
    ])
    return wav


def transcribe_words(wav: Path, language: str | None, model_name: str) -> list[Word]:
    from faster_whisper import WhisperModel

    model = WhisperModel(model_name, device="cpu", compute_type="int8")
    segments, _ = model.transcribe(
        str(wav), language=language, word_timestamps=True, vad_filter=True,
    )
    words: list[Word] = []
    for segment in segments:
        for word in segment.words or []:
            text = word.word.strip()
            if text:
                words.append(Word(text=text, start=word.start, end=word.end))
    return words


def obtain_words(video: Path, work: Path, args: argparse.Namespace) -> list[Word]:
    """Return word timestamps, reusing a cached transcript when one is valid."""
    cache_path = _transcript_key(video, args.model, args.lang)
    if not args.no_cache:
        cached = _load_transcript(cache_path)
        if cached is not None:
            log(f"Reusing cached transcript ({len(cached)} words, {cache_path})")
            return cached
    log(f"Transcribing (local whisper, model={args.model})...")
    started = time.perf_counter()
    words = transcribe_words(extract_audio(video, work), args.lang, args.model)
    log(f"Transcribed {len(words)} words in {time.perf_counter() - started:.1f}s")
    if words and not args.no_cache:
        _save_transcript(cache_path, words)
        log(f"Cached transcript to {cache_path} (rerun resumes at rendering)")
    return words


def group_words(words: list[Word], max_words: int, max_gap: float) -> list[list[Word]]:
    groups: list[list[Word]] = []
    current: list[Word] = []
    for word in words:
        if current and _should_break(current, word, max_words, max_gap):
            groups.append(current)
            current = []
        current.append(word)
    if current:
        groups.append(current)
    return groups


def _should_break(
    current: list[Word], word: Word, max_words: int, max_gap: float
) -> bool:
    return (
        len(current) >= max_words
        or word.start - current[-1].end > max_gap
        or current[-1].ends_sentence
    )


def _fmt_time(seconds: float) -> str:
    seconds = max(0.0, seconds)
    hours, rest = divmod(seconds, 3600)
    minutes, secs = divmod(rest, 60)
    return f"{int(hours)}:{int(minutes):02d}:{secs:05.2f}"


def _ass_colour(hex_colour: str, style_field: bool) -> str:
    c = hex_colour.lstrip("#")
    bgr = f"{c[4:6]}{c[2:4]}{c[0:2]}".upper()
    return f"&H00{bgr}" if style_field else f"&H{bgr}&"


def _dialogue_line(words: list[Word], active: int, highlight: str) -> str:
    tokens: list[str] = []
    for index, word in enumerate(words):
        if index == active:
            pop = r"\fscx100\fscy100\t(0,90,\fscx118\fscy118)"
            tokens.append(f"{{\\c{highlight}{pop}}}{word.display}{{\\r}}")
        else:
            tokens.append(f"{{\\r}}{word.display}")
    return " ".join(tokens)


def _group_events(
    group: list[Word], colour: str, next_start: float | None
) -> list[str]:
    events: list[str] = []
    for index, word in enumerate(group):
        start = group[0].start if index == 0 else word.start
        end = _word_end(group, index, word, next_start)
        text = _dialogue_line(group, index, colour)
        events.append(
            f"Dialogue: 0,{_fmt_time(start)},{_fmt_time(end)},Default,,0,0,0,,{text}"
        )
    return events


def _word_end(
    group: list[Word], index: int, word: Word, next_start: float | None
) -> float:
    if index + 1 < len(group):
        return group[index + 1].start
    tail = word.end + LAST_WORD_TAIL
    return tail if next_start is None else min(tail, next_start)


def build_ass(groups: list[list[Word]], style: Style) -> str:
    primary = _ass_colour("#FFFFFF", style_field=True)
    outline = _ass_colour("#000000", style_field=True)
    header = [
        "[Script Info]",
        "ScriptType: v4.00+",
        "WrapStyle: 0",
        "ScaledBorderAndShadow: yes",
        f"PlayResX: {style.play_w}",
        f"PlayResY: {style.play_h}",
        "",
        "[V4+ Styles]",
        "Format: Name, Fontname, Fontsize, PrimaryColour, SecondaryColour, "
        "OutlineColour, BackColour, Bold, Italic, Underline, StrikeOut, "
        "ScaleX, ScaleY, Spacing, Angle, BorderStyle, Outline, Shadow, "
        "Alignment, MarginL, MarginR, MarginV, Encoding",
        f"Style: Default,{FONT_NAME},{style.font_size},{primary},{primary},"
        f"{outline},&H64000000,1,0,0,0,100,100,0,0,1,{style.outline},2,"
        f"{style.alignment},40,40,{style.margin_v},1",
        "",
        "[Events]",
        "Format: Layer, Start, End, Style, Name, MarginL, MarginR, "
        "MarginV, Effect, Text",
    ]
    palette = [_ass_colour(colour, style_field=False) for colour in style.highlights]
    events: list[str] = []
    for index, group in enumerate(groups):
        next_start = groups[index + 1][0].start if index + 1 < len(groups) else None
        colour = palette[index % len(palette)]
        events.extend(_group_events(group, colour, next_start))
    return "\n".join(header + events) + "\n"


def ensure_font() -> Path:
    font_dir = CACHE / "fonts"
    font_path = font_dir / "Anton-Regular.ttf"
    if not font_path.exists():
        font_dir.mkdir(parents=True, exist_ok=True)
        urllib.request.urlretrieve(FONT_URL, font_path)  # noqa: S310 (fixed https url)
    return font_dir


def _quote_filter_path(path: Path) -> str:
    """Single-quote a path for an ffmpeg filtergraph option value.

    The plain positional form (subtitles=<path>:fontsdir=<path>) is rejected by
    ffmpeg 7/8's filtergraph parser even for ordinary paths; wrapping each value
    in single quotes and naming the option explicitly is the portable form.
    Backslashes are doubled; the controlled cache paths never contain quotes.
    """
    return "'" + str(path).replace("\\", "\\\\") + "'"


def burn(video: Path, ass_path: Path, font_dir: Path, out: Path) -> None:
    subs = _quote_filter_path(ass_path)
    fonts = _quote_filter_path(font_dir)
    run([
        "ffmpeg", "-y", "-loglevel", "error", "-i", str(video),
        "-vf", f"subtitles=filename={subs}:fontsdir={fonts}",
        "-c:a", "copy", str(out),
    ])


def build_style(width: int, height: int, args: argparse.Namespace) -> Style:
    font_size = int(height * args.scale)
    return Style(
        font_size=font_size,
        outline=max(3, round(font_size * 0.06)),
        highlights=args.highlight,
        max_words=args.words,
        max_gap=args.gap,
        play_w=width,
        play_h=height,
        margin_v=int(height * args.position),
        alignment=args.alignment,
    )


def _parse_palette(value: str) -> tuple[str, ...]:
    colours = tuple(part.strip() for part in value.split(",") if part.strip())
    if not colours:
        raise argparse.ArgumentTypeError("no colours given")
    for colour in colours:
        if not HEX_COLOUR.match(colour):
            raise argparse.ArgumentTypeError(f"invalid hex colour: {colour}")
    return tuple(c if c.startswith("#") else f"#{c}" for c in colours)


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Burn Hormozi-style captions into a video."
    )
    add = parser.add_argument
    add("video", type=Path, help="input video file")
    add("-o", "--output", type=Path, help="output (default <name>_captioned.mp4)")
    add(
        "--highlight",
        type=_parse_palette,
        default=DEFAULT_PALETTE,
        help="active-word colour: one hex for a fixed colour, or a comma-separated "
        "list to cycle per word (default: rainbow palette)",
    )
    add("--words", type=int, default=5, help="max words per line (default 5)")
    add("--gap", type=float, default=0.6, help="silence gap that breaks a line (s)")
    add("--scale", type=float, default=0.058, help="font size as fraction of height")
    add(
        "--alignment",
        type=int,
        default=2,
        help="which screen zone the captions anchor to (ASS numpad layout): "
        "1-3 = bottom left/centre/right, 4-6 = middle left/centre/right, "
        "7-9 = top left/centre/right. E.g. 2 = bottom-centre (default), "
        "8 = top-centre, 5 = dead-centre",
    )
    add(
        "--position",
        type=float,
        default=0.30,
        help="fine offset from the --alignment edge, as a fraction of video "
        "height: gap above the bottom edge for 1-3, gap below the top edge "
        "for 7-9, ignored for the vertically-centred row 4-6",
    )
    add("--model", default="small", help="faster-whisper model (default small)")
    add("--lang", default=None, help="force language code (default auto-detect)")
    add(
        "--no-cache",
        action="store_true",
        help="re-transcribe even if a cached transcript exists",
    )
    return parser.parse_args(argv)


def default_output(video: Path) -> Path:
    return video.with_name(f"{video.stem}_captioned.mp4")


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    if not args.video.exists():
        sys.exit(f"no such file: {args.video}")
    ensure_runtime()
    ensure_subtitles_filter()
    CACHE.mkdir(parents=True, exist_ok=True)
    work = CACHE / "work"
    work.mkdir(exist_ok=True)
    width, height = probe_dimensions(args.video)
    style = build_style(width, height, args)
    overall = time.perf_counter()
    words = obtain_words(args.video, work, args)
    if not words:
        sys.exit("no speech detected")
    groups = group_words(words, style.max_words, style.max_gap)
    ass_path = work / "captions.ass"
    ass_path.write_text(build_ass(groups, style), encoding="utf-8")
    output = args.output or default_output(args.video)
    log(f"Rendering {output.name}...")
    started = time.perf_counter()
    burn(args.video, ass_path, ensure_font(), output)
    log(f"Rendered {output.name} in {time.perf_counter() - started:.1f}s")
    log(f"Done in {time.perf_counter() - overall:.1f}s total")
    print(str(output))
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
