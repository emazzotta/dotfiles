#!/bin/bash
# Reusable interactive picker with fuzzy search.
#
# Reads newline-separated items from stdin, writes user's selection(s) to stdout.
# Scales to terminal height; supports single or multi select; backed by fzf
# (preferred) with gum filter as fallback.
#
# Usage:
#   picker [--header TEXT] [--multi] [--height ROWS|PERCENT%]
#
# Examples:
#   ls | picker --header "Pick a file:"
#   ps aux | picker --header "Pick processes:" --multi
#
# Exit codes:
#   0   selection made (output on stdout)
#   1   nothing selected / cancelled
#   2   usage error or missing backend

set -euo pipefail

header=""
multi=false
height=""

while [ $# -gt 0 ]; do
    case "$1" in
        --header) header="$2"; shift 2 ;;
        --multi) multi=true; shift ;;
        --height) height="$2"; shift 2 ;;
        -h|--help)
            sed -n '2,14p' "$0" | sed 's/^# \?//'
            exit 0
            ;;
        *) echo "picker: unknown option: $1" >&2; exit 2 ;;
    esac
done

[ -z "$height" ] && height="100%"

if command -v fzf &>/dev/null; then
    args=(
        --height "$height"
        --layout=reverse
        --border=rounded
        --margin=1
        --padding=1
        --no-sort
        --tiebreak=index
        --prompt='▶ '
        --pointer='❯'
        --marker='✓'
        --cycle
        --color=bg+:#2d1b3d,fg+:#ffffff,hl:#ff69b4,hl+:#ff79c6,prompt:#e75480,pointer:#e75480,marker:#bd93f9,header:#7d56f4,border:#7d56f4,info:#8b8b8b,spinner:#ff69b4
    )
    [ -n "$header" ] && args+=(--header "$header")
    [ "$multi" = true ] && args+=(--multi --header "${header:+$header }(tab=toggle)")
    fzf "${args[@]}"
elif command -v gum &>/dev/null; then
    rows=$(tput lines 2>/dev/null || echo 20)
    gum_height=$((rows - 4))
    [ "$gum_height" -lt 5 ] && gum_height=5
    args=(filter --height "$gum_height")
    [ -n "$header" ] && args+=(--header "$header")
    [ "$multi" = true ] && args+=(--no-limit)
    gum "${args[@]}"
else
    echo "picker: fzf or gum required" >&2
    exit 2
fi
