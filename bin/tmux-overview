#!/bin/bash
# tmux-overview - toggleable grid overview of all tmux panes in the current
# session. Creates a dedicated overview window where each source pane (across
# every window, not just the active pane per window) gets one real pane tile,
# live-capturing that specific pane. Tiles are arranged via tmux's built-in
# `tiled` layout for similar real estate.
#
# Subcommands:
#   tmux-overview             toggle the overview window
#   tmux-overview tile <win>  internal: render loop for one tile
#   tmux-overview open        internal: build overview (detached post-kill)
#   tmux-overview reconcile   internal: rebuild when session windows change
#   tmux-overview status      diagnostic info
#
# Debug log (tile mode): $TMPDIR/tmux-overview.log (falls back to /tmp)

set -uo pipefail

MARKER_WIN='@overview_window'
MARKER_PANE='@overview'
TILE_SOURCE_OPT='@tile_source'
PREV_WIN_OPT='@overview_prev_win'
REFRESH_SECONDS=0.5
LOG="${TMPDIR:-/tmp}/tmux-overview.log"

resolve_self() {
    local src="${BASH_SOURCE[0]}"
    local dir
    dir=$(cd "$(dirname "$src")" && pwd)
    printf '%s/%s' "$dir" "$(basename "$src")"
}

notify() {
    tmux display-message "overview: $*" 2>/dev/null || true
}

find_overview_window() {
    tmux list-windows -F "#{window_id} #{${MARKER_WIN}}" 2>/dev/null \
        | awk '$2 == "1" { print $1; exit }'
}

cleanup_legacy_panes() {
    # Kill any stale @overview panes left over from earlier (single-pane) design.
    local p
    while read -r p; do
        [ -n "$p" ] && tmux kill-pane -t "$p" 2>/dev/null || true
    done < <(tmux list-panes -s -F "#{pane_id} #{${MARKER_PANE}}" 2>/dev/null \
             | awk '$2 == "1" { print $1 }')
}

toggle() {
    if [ -z "${TMUX:-}" ]; then
        echo "tmux-overview: not inside a tmux session (TMUX unset)" >&2
        return 1
    fi

    local existing
    existing=$(find_overview_window)
    if [ -n "$existing" ]; then
        close_overview "$existing"
        return 0
    fi

    # Refuse if this is the only window - killing the launcher would destroy
    # the session and there'd be nothing to tile anyway.
    local win_count
    win_count=$(tmux list-windows -F '.' 2>/dev/null | wc -l)
    if [ "$win_count" -lt 2 ]; then
        notify "only one window; nothing to tile"
        return 1
    fi

    # The window running this command is the "launcher". Killing our own
    # window in-process is racy (the shell dies mid-script), and opening the
    # overview first then killing the launcher afterwards creates a transient
    # mismatch between session windows and tiled sources that the reconcile
    # loop fights against - producing endless rebuild cycles.
    #
    # Instead, detach a tmux server task that kills the launcher and then
    # reinvokes this script to build the overview against a clean session.
    # By the time open_overview lists windows, the launcher is already gone,
    # so the overview is correct from the first frame and no reconcile fires.
    local launcher_win self
    launcher_win=$(tmux display-message -p '#{window_id}')
    self=$(resolve_self)
    tmux run-shell -b "tmux kill-window -t '$launcher_win' 2>/dev/null; '$self' open" \
        2>/dev/null || return 1
}

close_overview() {
    local ov_win=$1
    local prev
    prev=$(tmux show-options -wvt "$ov_win" "$PREV_WIN_OPT" 2>/dev/null || true)
    if [ -n "$prev" ]; then
        tmux select-window -t "$prev" 2>/dev/null || true
    else
        tmux select-window -l 2>/dev/null || true
    fi
    tmux kill-window -t "$ov_win"
    notify "closed"
}

open_overview() {
    local mode=${1:-attached}
    local self; self=$(resolve_self)
    if [ ! -x "$self" ]; then
        notify "script not executable: $self"; return 1
    fi

    local prev_win
    prev_win=$(tmux display-message -p '#{window_id}')

    # Source = every pane in every window of the current session. Skip any
    # overview window in case one slipped through (toggle kills it before this
    # runs, and reconcile calls close_overview first, so this is defensive).
    local existing_ov
    existing_ov=$(find_overview_window)

    local -a sources=()
    local w p
    while IFS=' ' read -r w p; do
        [ -z "$p" ] && continue
        [ -n "$existing_ov" ] && [ "$w" = "$existing_ov" ] && continue
        sources+=("$p")
    done < <(tmux list-panes -s -F '#{window_id} #{pane_id}')
    local n=${#sources[@]}
    if [ "$n" -eq 0 ]; then
        notify "no panes to tile"; return 1
    fi

    local -a new_win_args=(-P -F '#{window_id}|#{pane_id}' -n overview)
    [ "$mode" = "detached" ] && new_win_args+=(-d)

    local out ov_win first_pane
    if ! out=$(tmux new-window "${new_win_args[@]}" \
                   "exec $self tile ${sources[0]}" 2>&1); then
        notify "new-window failed: $out"; return 1
    fi
    ov_win="${out%|*}"
    first_pane="${out#*|}"

    tmux set-option -wt "$ov_win" "$MARKER_WIN" 1 2>/dev/null || true
    tmux set-option -wt "$ov_win" "$PREV_WIN_OPT" "$prev_win" 2>/dev/null || true
    tmux set-option -pt "$first_pane" "$MARKER_PANE" 1 2>/dev/null || true
    tmux set-option -pt "$first_pane" "$TILE_SOURCE_OPT" "${sources[0]}" 2>/dev/null || true

    if [ "$n" -eq 1 ]; then
        notify "opened (1 tile)"
        return 0
    fi

    # Pick columns by scoring each candidate on two axes:
    #   ratio  = widest_tile / narrowest_tile (penalises lopsided last rows)
    #   aspect = max(cols/rows, rows/cols)    (penalises long-thin grids)
    # Score = ratio + 0.2 * aspect. Tiebreak prefers larger cols (wider grid).
    local cols rows
    cols=$(awk -v n="$n" 'BEGIN {
        best_c = 1; best_score = 1e9
        for (c = 1; c <= n; c++) {
            r = int((n + c - 1) / c)
            lc = n - (r - 1) * c
            ratio = (lc == c) ? 1.0 : (c / lc)
            aspect = (c > r) ? (c / r) : (r / c)
            score = ratio + 0.2 * aspect
            if (score < best_score || (score == best_score && c > best_c)) {
                best_score = score; best_c = c
            }
        }
        print best_c
    }')
    rows=$(( (n + cols - 1) / cols ))

    # Phase 1: (rows - 1) vertical splits of first_pane produce `rows` equal-height rows.
    # Split k (1..rows-1) adds a pane just below first_pane; because later splits push
    # earlier ones down, split k ends up at row index (rows - k).
    local -a row_heads
    row_heads[0]=$first_pane
    local k size row_idx src_idx src new_pane
    for (( k = 1; k < rows; k++ )); do
        size=$(( 100 / (rows - k + 1) ))
        row_idx=$(( rows - k ))
        src_idx=$(( row_idx * cols ))
        src="${sources[$src_idx]}"
        new_pane=$(tmux split-window -v -t "$first_pane" -P -F '#{pane_id}' -l "${size}%" \
                       "exec $self tile $src" 2>/dev/null) || continue
        tmux set-option -pt "$new_pane" "$MARKER_PANE" 1 2>/dev/null || true
        tmux set-option -pt "$new_pane" "$TILE_SOURCE_OPT" "$src" 2>/dev/null || true
        row_heads[row_idx]=$new_pane
    done

    # Phase 2: fill each row with columns via horizontal splits of the row head.
    local r row_head row_start row_cols col_idx
    for (( r = 0; r < rows; r++ )); do
        row_head="${row_heads[$r]}"
        row_start=$(( r * cols ))
        if [ "$r" -eq $(( rows - 1 )) ]; then
            row_cols=$(( n - row_start ))
        else
            row_cols=$cols
        fi
        [ "$row_cols" -lt 2 ] && continue
        for (( k = 1; k < row_cols; k++ )); do
            size=$(( 100 / (row_cols - k + 1) ))
            col_idx=$(( row_cols - k ))
            src_idx=$(( row_start + col_idx ))
            src="${sources[$src_idx]}"
            new_pane=$(tmux split-window -h -t "$row_head" -P -F '#{pane_id}' -l "${size}%" \
                           "exec $self tile $src" 2>/dev/null) || continue
            tmux set-option -pt "$new_pane" "$MARKER_PANE" 1 2>/dev/null || true
            tmux set-option -pt "$new_pane" "$TILE_SOURCE_OPT" "$src" 2>/dev/null || true
        done
    done

    notify "opened ($n tiles, ${cols}x${rows} grid)"
}

render_tile() {
    local src_pane=$1
    local self_pane=${TMUX_PANE:?TMUX_PANE unset}

    # Detect a dead source pane via list-panes -s instead of display-message:
    # display-message -t @dead silently returns empty + exit 0 (tmux falls back
    # to the current pane), so it can't be trusted as a liveness check.
    if ! tmux list-panes -s -F '#{pane_id}' 2>/dev/null | grep -qxF "$src_pane"; then
        return 2
    fi

    local info
    info=$(tmux display-message -t "$src_pane" -p '#{window_index}|#{window_name}|#{pane_index}' 2>/dev/null)
    if [ -z "$info" ]; then
        return 2
    fi
    local win_idx="${info%%|*}"; info="${info#*|}"
    local win_name="${info%%|*}"
    local pane_idx="${info#*|}"

    local dims tile_h tile_w
    dims=$(tmux display-message -pt "$self_pane" -p '#{pane_height} #{pane_width}' 2>/dev/null) || return
    tile_h=${dims% *}
    tile_w=${dims#* }

    local content_lines=$(( tile_h - 1 ))
    [ "$content_lines" -lt 1 ] && content_lines=1

    local header
    header=$(printf '── [%s.%s:%s] %s ──' "$win_idx" "$pane_idx" "$win_name" "$src_pane")

    # -e preserves ANSI escape sequences (colors). cut -c would split mid-escape
    # and corrupt them, so we skip byte-truncation and let long source lines wrap.
    local captured
    captured=$(tmux capture-pane -t "$src_pane" -ep 2>/dev/null \
        | awk 'BEGIN{last=0} { buf[NR]=$0; if ($0 ~ /[^[:space:]]/) last=NR } END{ for (i=1; i<=last; i++) print buf[i] }' \
        | tail -n "$content_lines")
    [ -z "$captured" ] && captured='(empty)'

    # \033[0m resets attributes so a colored tail from last frame doesn't bleed
    # into this frame's header or into neighbouring tiles.
    printf '\033[0m\033[H\033[J%s\n%s\033[0m' "${header:0:$tile_w}" "$captured"
}

is_leader_tile() {
    # The tile at the top-left of the overview window acts as leader. It runs
    # reconciliation duty so we don't have every tile checking the same thing.
    local ov_win first_pane
    ov_win=$(tmux display-message -pt "$TMUX_PANE" -p '#{window_id}' 2>/dev/null) || return 1
    first_pane=$(tmux list-panes -t "$ov_win" -F '#{pane_id}' 2>/dev/null | head -1)
    [ "$TMUX_PANE" = "$first_pane" ]
}

trigger_reconcile_if_stale() {
    # Compare the set of session panes (excluding the overview window's own
    # tiles) to the set of @tile_source values on panes in the overview window.
    # If they differ - new pane, split, closed pane, new window - kick off a
    # background reconcile (close + reopen) so the overview matches reality.
    local ov_win session tiled self
    ov_win=$(tmux display-message -pt "$TMUX_PANE" -p '#{window_id}' 2>/dev/null) || return
    session=$(tmux list-panes -s -F '#{window_id} #{pane_id}' 2>/dev/null \
              | awk -v ov="$ov_win" '$1 != ov {print $2}' | sort -u)
    tiled=$(tmux list-panes -t "$ov_win" -F "#{${TILE_SOURCE_OPT}}" 2>/dev/null \
            | grep -v '^$' | sort -u)
    if [ "$session" != "$tiled" ]; then
        self=$(resolve_self)
        tmux run-shell -b "$self reconcile" 2>/dev/null || true
    fi
}

tile() {
    local src_pane=${1:?tile requires a source pane id}
    : > "$LOG"
    printf '\033[?25l'
    trap 'printf "\033[?25h\033[H\033[J"' EXIT

    local rc self
    while :; do
        render_tile "$src_pane" 2>>"$LOG"
        rc=$?
        if [ "$rc" -eq 2 ]; then
            # My source pane is gone. Trigger a reconcile so the overview
            # layout rebalances without me, then exit cleanly.
            self=$(resolve_self)
            tmux run-shell -b "$self reconcile" 2>/dev/null || true
            exit 0
        fi
        if is_leader_tile; then
            trigger_reconcile_if_stale
        fi
        sleep "$REFRESH_SECONDS"
    done
}

reconcile() {
    # Rebuild the overview so tiled sources match the current session windows.
    # Simple close + reopen keeps the code paths identical to a fresh toggle.
    # Guarded by a global tmux option to prevent overlapping rebuilds when
    # multiple triggers fire in the same tick.
    local existing
    existing=$(find_overview_window)
    [ -z "$existing" ] && return 0

    local lock
    lock=$(tmux show-options -gv "@overview_lock" 2>/dev/null || true)
    [ "$lock" = "1" ] && return 0
    tmux set-option -g "@overview_lock" 1 2>/dev/null || true

    # Capture the user's actual focused window before tearing anything down.
    # display-message inside run-shell -b reports the invoking pane (a tile),
    # so query window_active directly instead.
    local user_win
    user_win=$(tmux list-windows -F '#{window_active} #{window_id}' 2>/dev/null \
               | awk '$1=="1" {print $2; exit}')
    local user_was_watching=0
    [ "$user_win" = "$existing" ] && user_was_watching=1

    local prev
    prev=$(tmux show-options -wvt "$existing" "$PREV_WIN_OPT" 2>/dev/null || true)
    close_overview "$existing"
    [ -n "$prev" ] && tmux select-window -t "$prev" 2>/dev/null || true

    if [ "$user_was_watching" = "1" ]; then
        open_overview
    else
        open_overview detached
        # Restore the user's focus if their window still exists. It may have
        # been the one whose deletion triggered this reconcile in the first
        # place; in that case tmux has already moved focus elsewhere and we
        # leave it alone.
        if [ -n "$user_win" ] \
           && tmux list-windows -F '#{window_id}' 2>/dev/null | grep -qxF "$user_win"; then
            tmux select-window -t "$user_win" 2>/dev/null || true
        fi
    fi

    tmux set-option -gu "@overview_lock" 2>/dev/null || true
}

status() {
    printf 'tmux-overview path: %s\n' "$(resolve_self)"
    printf 'tmux version: '; tmux -V 2>/dev/null || echo '(not found)'
    printf 'TMUX: %s\n' "${TMUX:-(unset)}"
    printf 'TMUX_PANE: %s\n' "${TMUX_PANE:-(unset)}"
    printf 'PATH: %s\n' "$PATH"
    printf 'log file: %s\n' "$LOG"
    if [ -f "$LOG" ]; then
        printf -- '--- last 20 log lines ---\n'
        tail -n 20 "$LOG"
    else
        printf '(no log yet)\n'
    fi
}

case "${1:-toggle}" in
    toggle)    toggle ;;
    tile)      shift; tile "$@" ;;
    reconcile) reconcile ;;
    open)
        # Internal: invoked by toggle's detached worker after killing the
        # launcher window. Guarded against double-open in case a second
        # toggle raced during the kill-and-open gap.
        if [ -n "$(find_overview_window)" ]; then
            notify "overview already open"
            exit 0
        fi
        cleanup_legacy_panes
        open_overview
        ;;
    status)    status ;;
    *)         echo "Usage: $(basename "$0") [toggle|tile|reconcile|open|status]" >&2; exit 1 ;;
esac
