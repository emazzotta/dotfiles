{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/session-start-memory.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/opencode/.claude/hooks/stop-verify.sh"
          },
          {
            "type": "command",
            "command": "printf '\\a'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/user-prompt-session-topic.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"${CLAUDE_TOOL_INPUT_FILE_PATH:-}${CLAUDE_TOOL_INPUT_file_path:-}\"; case \"$file\" in */knowledge/memory/*) exit 0;; */memory/*|*/.claude/projects/*/memory*) echo 'BLOCKED: auto-memory path. For curated session memory use /workspace/.claude/scripts/memory log \"<text>\" (or park/recall). See Session Memory in CLAUDE.md.'; exit 2;; esac; exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"${CLAUDE_TOOL_INPUT_FILE_PATH:-}${CLAUDE_TOOL_INPUT_file_path:-}\"; case \"$file\" in */CLAUDE.md|*/AGENTS.md|*/OPENCODE.md) echo 'SYNC REQUIRED: You just edited a synced file. CLAUDE.md, AGENTS.md, and OPENCODE.md must be identical. Update the other two files now.';; esac; exit 0"
          },
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/post-edit-autocomplete-check.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/post-tool-commit-observer.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/opt/ccline/ccline"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "model": "opus[1m]"
}
